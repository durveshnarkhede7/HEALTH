      "hormonal": ["HOR_ESTROGEN_001", "HOR_CORTISOL_001"],
      "lifestyle": "Physical inactivity, smoking (reduces osteoblast activity), alcohol (reduces osteoblast activity, impairs calcium absorption)",
      "aging": "LIF_AGING_001"
    },
