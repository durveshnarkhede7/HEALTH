  "BIO_HAIRBULB_001": {
    "id": "BIO_HAIRBULB_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Hair Bulb",
    "parent_system": "SYS_HAIR_001",
    "parent_structure": "BIO_FOLLICLE_001",
    "definition": "The onion-shaped base of the anagen hair follicle enclosing the dermal papilla and containing the most metabolically active cell populations of the follicle \u2014 the hair matrix keratinocytes and the follicular melanocytes. The hair bulb is the site of hair shaft production and pigmentation.",
    "function": "Houses the continuously dividing matrix cells that generate the hair shaft and inner root sheath. Contains melanocytes that synthesise and inject pigment granules (melanosomes) into the cortical keratinocytes of the growing shaft \u2014 determining hair colour. Maintains the highest oxygen consumption rate of any non-cancerous normal tissue in the body.",
    "cellular_mechanism": "Matrix keratinocytes in the hair bulb divide every 12 to 24 hours \u2014 among the fastest dividing cells in the human body. After division one daughter cell continues mitosis, the other begins upward migration and progressive differentiation. As cells ascend through the follicle, they flatten, accumulate keratin intermediate filament proteins, form disulphide crosslinks between cysteine residues, and ultimately lose their nucleus via cornification \u2014 producing the anucleate dead keratin-packed cells of the hair shaft layers.",
    "hair_shaft_architecture": {
      "medulla": "Central loosely organised cells \u2014 absent in fine hair. Not structurally critical.",
      "cortex": "Main structural component \u2014 tightly packed cortical keratinocytes with disulphide-bonded keratin macrofibrils. Determines tensile strength and elasticity.",
      "cuticle": "Outermost overlapping scale-like cells \u2014 determines surface smoothness, light reflection, and resistance to chemical damage.",
      "inner_root_sheath": "Moulds the hair shaft to its cylindrical shape as it ascends. Composed of trichohyalin-rich cells."
    },
    "molecular_mechanism": {
      "keratin_synthesis": {
        "process": "Keratinocytes transcribe KRT31 to KRT40 (hard keratin) genes \u2192 translate keratin polypeptide chains \u2192 assemble intermediate filaments \u2192 pack tightly via disulphide bonds between cysteine residues",
        "cysteine_dependency": "Hair cortex keratin contains 14 to 22 percent cysteine \u2014 far higher than any other tissue protein. Dietary cysteine and methionine (cysteine precursor) are rate-limiting substrates for keratin synthesis. Ref: NUT_PROTEIN_001",
        "zinc_transcription": "Zinc finger proteins regulate KRT gene transcription. Zinc deficiency reduces keratin gene expression \u2192 structurally weak shafts \u2192 brittleness and breakage"
      },
      "melanocyte_biology": {
        "melanocyte_location": "Follicular melanocytes are in two populations: active ones in the hair bulb (inject pigment into matrix keratinocytes) and melanocyte stem cells in the bulge (replenish active melanocytes each anagen cycle)",
        "pigment_synthesis": "L-tyrosine \u2192 DOPA \u2192 dopaquinone (by tyrosinase enzyme) \u2192 eumelanin (dark) or phaeomelanin (red/yellow) depending on cysteine availability in reaction",
        "melanosome_transfer": "Melanosomes transferred via cytoplasmic dendritic extrusions into adjacent cortical keratinocytes \u2192 pigment distributed in cortex \u2192 hair colour determined by ratio of eumelanin to phaeomelanin",
        "copper_dependency": "Tyrosinase is a copper-dependent enzyme. Copper deficiency impairs melanin synthesis. Ref: NUT_COPPER_001"
      },
      "greying_mechanism": {
        "primary_cause": "Progressive depletion of melanocyte stem cells in the bulge \u2014 each anagen cycle the replenishment pool diminishes \u2192 fewer active melanocytes \u2192 less pigment transferred \u2192 grey hair",
        "oxidative_acceleration": "Hydrogen peroxide (H2O2) accumulates in hair follicle with age as catalase enzyme activity declines. H2O2 bleaches existing pigment and causes oxidative DNA damage to melanocyte stem cells \u2014 accelerating their depletion. Ref: OXI_FREE_RADICAL_001",
        "B12_connection": "B12 is required for methionine synthase \u2192 homocysteine to methionine conversion \u2192 SAM production \u2192 DNA methylation protecting melanocyte stem cell genome. B12 deficiency \u2192 impaired DNA repair in melanocytes \u2192 premature depletion \u2192 premature greying. Ref: NUT_B12_001",
        "stress_connection": "Chronic catecholamine (adrenaline) release from sympathetic nervous system \u2192 directly targets melanocyte stem cells \u2192 rapid depletion \u2192 acute greying (the mechanism behind stress-induced greying in humans)"
      },
      "oxygen_metabolism": {
        "rate": "Hair bulb oxygen consumption is approximately 0.5 to 1 mL O2 per gram tissue per minute \u2014 comparable to cardiac muscle during moderate exercise",
        "iron_dependency": "Haemoglobin oxygen carrying capacity determines oxygen delivery to bulb capillaries. Serum ferritin below 70 ng/mL reduces tissue oxygen delivery sufficiently to impair matrix mitosis even without anaemia",
        "hypoxia_response": "Matrix cells under hypoxia \u2192 HIF-1alpha transcription factor activation \u2192 shifts to anaerobic glycolysis \u2192 less ATP \u2192 impaired division \u2192 catagen entry",
        "ref": "NUT_IRON_001"
      }
    },
    "cross_system_connections": {
