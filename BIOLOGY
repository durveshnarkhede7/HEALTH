  "BIO_HAIRBULB_001": {
    "id": "BIO_HAIRBULB_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Hair Bulb",
    "parent_system": "SYS_HAIR_001",
    "parent_structure": "BIO_FOLLICLE_001",
    "definition": "The onion-shaped base of the anagen hair follicle enclosing the dermal papilla and containing the most metabolically active cell populations of the follicle — the hair matrix keratinocytes and the follicular melanocytes. The hair bulb is the site of hair shaft production and pigmentation.",
    "function": "Houses the continuously dividing matrix cells that generate the hair shaft and inner root sheath. Contains melanocytes that synthesise and inject pigment granules (melanosomes) into the cortical keratinocytes of the growing shaft — determining hair colour. Maintains the highest oxygen consumption rate of any non-cancerous normal tissue in the body.",
    "cellular_mechanism": "Matrix keratinocytes in the hair bulb divide every 12 to 24 hours — among the fastest dividing cells in the human body. After division one daughter cell continues mitosis, the other begins upward migration and progressive differentiation. As cells ascend through the follicle, they flatten, accumulate keratin intermediate filament proteins, form disulphide crosslinks between cysteine residues, and ultimately lose their nucleus via cornification — producing the anucleate dead keratin-packed cells of the hair shaft layers.",
    "hair_shaft_architecture": {
      "medulla": "Central loosely organised cells — absent in fine hair. Not structurally critical.",
      "cortex": "Main structural component — tightly packed cortical keratinocytes with disulphide-bonded keratin macrofibrils. Determines tensile strength and elasticity.",
      "cuticle": "Outermost overlapping scale-like cells — determines surface smoothness, light reflection, and resistance to chemical damage.",
      "inner_root_sheath": "Moulds the hair shaft to its cylindrical shape as it ascends. Composed of trichohyalin-rich cells."
    },
    "molecular_mechanism": {
      "keratin_synthesis": {
        "process": "Keratinocytes transcribe KRT31 to KRT40 (hard keratin) genes → translate keratin polypeptide chains → assemble intermediate filaments → pack tightly via disulphide bonds between cysteine residues",
        "cysteine_dependency": "Hair cortex keratin contains 14 to 22 percent cysteine — far higher than any other tissue protein. Dietary cysteine and methionine (cysteine precursor) are rate-limiting substrates for keratin synthesis. Ref: NUT_PROTEIN_001",
        "zinc_transcription": "Zinc finger proteins regulate KRT gene transcription. Zinc deficiency reduces keratin gene expression → structurally weak shafts → brittleness and breakage"
      },
      "melanocyte_biology": {
        "melanocyte_location": "Follicular melanocytes are in two populations: active ones in the hair bulb (inject pigment into matrix keratinocytes) and melanocyte stem cells in the bulge (replenish active melanocytes each anagen cycle)",
        "pigment_synthesis": "L-tyrosine → DOPA → dopaquinone (by tyrosinase enzyme) → eumelanin (dark) or phaeomelanin (red/yellow) depending on cysteine availability in reaction",
        "melanosome_transfer": "Melanosomes transferred via cytoplasmic dendritic extrusions into adjacent cortical keratinocytes → pigment distributed in cortex → hair colour determined by ratio of eumelanin to phaeomelanin",
        "copper_dependency": "Tyrosinase is a copper-dependent enzyme. Copper deficiency impairs melanin synthesis. Ref: NUT_COPPER_001"
      },
      "greying_mechanism": {
        "primary_cause": "Progressive depletion of melanocyte stem cells in the bulge — each anagen cycle the replenishment pool diminishes → fewer active melanocytes → less pigment transferred → grey hair",
        "oxidative_acceleration": "Hydrogen peroxide (H2O2) accumulates in hair follicle with age as catalase enzyme activity declines. H2O2 bleaches existing pigment and causes oxidative DNA damage to melanocyte stem cells — accelerating their depletion. Ref: OXI_FREE_RADICAL_001",
        "B12_connection": "B12 is required for methionine synthase → homocysteine to methionine conversion → SAM production → DNA methylation protecting melanocyte stem cell genome. B12 deficiency → impaired DNA repair in melanocytes → premature depletion → premature greying. Ref: NUT_B12_001",
        "stress_connection": "Chronic catecholamine (adrenaline) release from sympathetic nervous system → directly targets melanocyte stem cells → rapid depletion → acute greying (the mechanism behind stress-induced greying in humans)"
      },
      "oxygen_metabolism": {
        "rate": "Hair bulb oxygen consumption is approximately 0.5 to 1 mL O2 per gram tissue per minute — comparable to cardiac muscle during moderate exercise",
        "iron_dependency": "Haemoglobin oxygen carrying capacity determines oxygen delivery to bulb capillaries. Serum ferritin below 70 ng/mL reduces tissue oxygen delivery sufficiently to impair matrix mitosis even without anaemia",
        "hypoxia_response": "Matrix cells under hypoxia → HIF-1alpha transcription factor activation → shifts to anaerobic glycolysis → less ATP → impaired division → catagen entry",
        "ref": "NUT_IRON_001"
      }
    },
    "cross_system_connections": {
      "to_energy_system": "BIO_MITOCHONDRIA_001 provides all ATP for matrix cell division. Iron deficiency impairs both oxygen delivery AND mitochondrial ETC function simultaneously.",
      "to_digestive_system": "Amino acid absorption from gut lining (BIO_GUTLINING_001) is prerequisite for keratin synthesis substrate.",
      "to_hormonal_system": "HOR_DHT_001 acts via BIO_DERMALPAPILLA_001 to reduce matrix cell population. HOR_THYROID_001 directly regulates matrix keratinocyte metabolic rate."
    },
    "damage_pathways": {
      "nutritional": ["NUT_IRON_001", "NUT_COPPER_001", "NUT_B12_001", "NUT_PROTEIN_001", "NUT_ZINC_001"],
      "oxidative": ["OXI_FREE_RADICAL_001"],
      "hormonal": ["HOR_DHT_001"],
      "inflammatory": ["INF_CHRONIC_001"]
    },
    "recovery_pathways": {
      "nutritional": ["NUT_IRON_001", "NUT_PROTEIN_001", "NUT_SELENIUM_001", "NUT_COPPER_001"],
      "recovery_timeline": "REC_FOLLICLE_001"
    },
    "tags": ["hair bulb", "melanocytes", "keratinocytes", "pigmentation", "greying", "tyrosinase", "copper", "hydrogen peroxide", "melanocyte stem cells", "oxygen dependence", "keratin synthesis"]
  },
  "BIO_MATRIX_001": {
    "id": "BIO_MATRIX_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Hair Matrix",
    "parent_system": "SYS_HAIR_001",
    "parent_structure": "BIO_FOLLICLE_001",
    "definition": "The population of undifferentiated keratinocytes occupying the basal region of the hair bulb, surrounding the apex of the dermal papilla. The matrix is the engine of hair shaft production — the highest mitotic rate tissue in the body (barring bone marrow), generating the 5 concentric layers of the hair shaft and inner root sheath through continuous division and upward differentiation.",
    "function": "Generates all structural layers of the hair shaft through asymmetric cell division and upward terminal differentiation. Rate of matrix mitosis directly determines hair shaft diameter and linear growth speed. Matrix is exquisitely sensitive to any systemic nutritional, hormonal, or toxic signal that reduces cellular energy or substrate availability.",
    "cellular_mechanism": "Matrix cells undergo asymmetric division — one daughter remains as a progenitor, the other begins a 14-day differentiation journey upward. Differentiating cells progress through pre-cortical, cortical, and cuticular zones, accumulating type II hard keratin proteins at each stage. They flatten progressively, disulphide crosslinks form between cysteine-rich keratin chains, and the nucleus is dissolved in a process of controlled autolysis — producing the completely keratinised dead cells of the mature hair shaft.",
    "mitotic_rate_context": "Matrix cells divide every 12 to 24 hours. For comparison: intestinal epithelium divides every 24 to 48 hours; liver hepatocytes divide only when regenerating. This extreme mitotic rate is why hair is one of the first tissues affected by ANY systemic stress — the matrix is uniquely vulnerable because it has almost no reserve capacity.",
    "molecular_mechanism": {
      "iron_and_DNA_synthesis": {
        "enzyme": "Ribonucleotide reductase (RNR) — the rate-limiting enzyme in deoxyribonucleotide synthesis for all cell division",
        "iron_role": "RNR contains a diferric-tyrosyl radical active site — absolutely requires iron for catalytic activity. Without iron, RNR cannot convert ribonucleotides to deoxyribonucleotides → DNA synthesis halts → cell cycle arrest at S phase → matrix cell division fails",
        "clinical_threshold": "Ferritin below 70 ng/mL is the functional iron threshold for hair. Matrix RNR is impaired before haemoglobin drops → hair loss precedes anaemia. This explains why treating hair loss only after Hb drops is too late.",
        "ref": "NUT_IRON_001"
      },
      "B12_and_methylation_cycle": {
        "B12_role_in_matrix": "B12 is cofactor for methionine synthase → converts homocysteine to methionine → methionine converted to SAM (S-adenosylmethionine) → SAM is the universal methyl donor for DNA methylation, histone methylation, and gene silencing",
        "deficiency_consequence": "B12 deficiency → elevated homocysteine → reduced SAM → impaired DNA methylation → dysregulated gene expression in matrix cells → impaired differentiation and division → compromised shaft quality and telogen effluvium",
        "folate_synergy": "Folate works with B12 in the one-carbon cycle. Both required for nucleotide synthesis (thymidylate) in dividing cells. Deficiency of either produces megaloblastic changes in high-turnover tissues — same mechanism as in RBCs.",
        "ref": "NUT_B12_001"
      },
      "zinc_and_gene_expression": {
        "zinc_fingers": "Over 2,500 human transcription factors contain zinc finger domains. In matrix keratinocytes, zinc-dependent transcription factors regulate KRT (keratin) genes, p63 (stem cell transcription factor), and PCNA (proliferating cell nuclear antigen — DNA replication essential protein)",
        "deficiency_consequence": "Zinc deficiency → impaired zinc finger transcription factor function → reduced keratin gene expression → structurally weak hair shafts prone to mid-shaft breakage. Clinically distinguishable from root shedding by breakage pattern.",
        "ref": "NUT_ZINC_001"
      },
      "protein_amino_acid_supply": {
        "keratin_composition": "Hair cortex keratin is 95 percent protein by dry weight. It contains 14 to 22 percent cysteine — far exceeding any other tissue protein. Also requires glycine, serine, proline, threonine.",
        "triage_hierarchy": "In protein deficiency, the body maintains plasma protein (albumin), immune protein, and cardiac protein synthesis first. Hair keratin synthesis is deprioritised → matrix cells begin differentiating with incomplete keratin load → weak, thin shafts first, then telogen effluvium as matrix mitosis rate falls",
        "ref": "NUT_PROTEIN_001"
      },
      "thyroid_T3_regulation": {
        "receptor": "T3 binds nuclear thyroid hormone receptor (TR-alpha1) in matrix keratinocytes — one of the highest TR-alpha1 expressing tissues in the body",
        "mechanism": "T3-TR complex → binds thyroid response elements → regulates transcription of ~500 matrix cell target genes governing metabolism, keratin production rate, and cell cycle progression",
