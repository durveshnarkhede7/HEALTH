  "BIO_PANCREAS_001": {
    "id": "BIO_PANCREAS_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Pancreas",
    "parent_system": "SYS_METABOLIC_001",
    "definition": "A retroperitoneal gland weighing 60 to 100 grams with dual exocrine (acinar cells) and endocrine (islets of Langerhans) populations. The endocrine pancreas \u2014 representing only 1 to 2 percent of total pancreatic mass \u2014 is the exclusive site of insulin, glucagon, and somatostatin production and the master regulator of blood glucose homeostasis.",
    "function": "Exocrine: secretes 1.5 to 2 litres of enzyme-rich bicarbonate fluid daily into the duodenum via the pancreatic duct \u2014 lipase (fat digestion), amylase (starch), elastase and trypsin/chymotrypsin (protein). Endocrine: islets of Langerhans secrete insulin (beta cells \u2014 65-80 percent of islet), glucagon (alpha cells \u2014 15-20 percent), somatostatin (delta cells \u2014 5 percent), and pancreatic polypeptide (PP cells) directly into portal vein.",
    "islet_cellular_detail": {
      "beta_cells": {
        "glucose_sensing": "Express GLUT2 (high Km \u2014 non-saturable at physiological glucose) and glucokinase (rate-limiting glucose-sensing enzyme). This combination makes beta cells exquisite glucose concentration sensors.",
        "secretion_mechanism": "Glucose \u2192 glycolysis \u2192 ATP:ADP ratio rises \u2192 KATP channels close \u2192 membrane depolarisation \u2192 voltage-gated Ca2+ channels open \u2192 Ca2+ influx \u2192 insulin granule fusion with plasma membrane \u2192 insulin exocytosis",
        "zinc_storage": "Insulin is stored in crystalline form as a Zn2+-insulin hexamer in secretory granules. Six insulin molecules coordinate 2 zinc ions to form stable hexamer. Zinc is required for insulin crystallisation, storage, and pH-triggered monomerisation during exocytosis. Zinc deficiency impairs insulin storage capacity and secretion efficiency. Ref: NUT_ZINC_001",
        "first_phase_second_phase": "First phase: pre-formed granule exocytosis within 1 to 3 minutes of glucose stimulus. Second phase: de novo insulin synthesis and newly granulated exocytosis over next 60 to 90 minutes. Type 2 diabetes \u2014 first phase blunted early, both phases reduced later."
      },
      "alpha_cells": {
        "glucagon": "Secreted when glucose falls. Stimulates hepatic glycogenolysis (glycogen breakdown \u2192 glucose) and gluconeogenesis (amino acid \u2192 glucose). Prevents hypoglycaemia between meals.",
        "suppression": "Normally suppressed by adjacent beta cell insulin and somatostatin. In T2DM \u2192 inappropriately elevated glucagon \u2192 contributes to fasting hyperglycaemia."
      },
      "delta_cells": {
        "somatostatin": "Paracrine inhibitor of both insulin and glucagon secretion. Fine-tunes postprandial islet hormone balance."
      }
    },
    "molecular_mechanism": {
      "insulin_resistance_progression": {
        "stage_1_compensated": "Tissue insulin resistance \u2192 reduced GLUT4 translocation \u2192 hyperglycaemia \u2192 beta cells compensate by increasing insulin secretion \u2192 hyperinsulinaemia maintains normoglycaemia. Duration: years to decades.",
        "stage_2_impaired_fasting": "Beta cell mass starts declining (glucotoxicity, lipotoxicity, ER stress, mitochondrial ROS) \u2192 insufficient insulin to maintain fasting normoglycaemia \u2192 impaired fasting glucose (IFG: 100-125 mg/dL)",
        "stage_3_T2DM": "Beta cell function below 50 percent of original capacity \u2192 frank hyperglycaemia regardless of insulin dose \u2192 type 2 diabetes diagnosis"
      },
      "glucotoxicity": {
        "mechanism": "Persistently elevated blood glucose \u2192 increased glucose flux through mitochondrial ETC in beta cells \u2192 superoxide overproduction \u2192 activation of stress kinases (JNK, p38) \u2192 pdx1 transcription factor downregulation \u2192 reduced insulin gene transcription \u2192 beta cell dedifferentiation and apoptosis",
        "ROS_specificity": "Beta cells express exceptionally low levels of antioxidant enzymes (catalase, GPx) compared to other tissues \u2014 making them uniquely susceptible to oxidative stress from excess glucose"
      },
      "lipotoxicity": {
        "mechanism": "Chronically elevated fatty acids (from insulin resistance-driven lipolysis) \u2192 ceramide synthesis in beta cells \u2192 protein phosphatase 2A activation \u2192 Akt dephosphorylation \u2192 apoptosis. Saturated fatty acids (palmitate, stearate) more lipotoxic than unsaturated. Ref: NUT_OMEGA3_001 for protective mechanism"
      },
      "zinc_insulin_connection": {
        "synthesis": "Zinc incorporated into insulin hexamers during proinsulin conversion to insulin in the trans-Golgi",
        "crystal_pH": "At pH 7.4 (blood) \u2192 hexamers dissociate to monomers (active form). Within granule pH 5-6 \u2192 hexamer stable. pH change during exocytosis triggers monomerisation.",
        "deficiency_consequence": "Zinc deficiency \u2192 disrupted hexamer formation \u2192 impaired insulin storage and granule maturity \u2192 reduced first-phase secretion. Zinc also required for insulin-degrading enzyme (IDE) activity \u2014 deficiency alters insulin clearance.",
        "ref": "NUT_ZINC_001"
      },
      "incretin_pathway": {
        "GLP1": "Glucagon-like peptide-1 secreted by L cells in ileum and colon in response to nutrients \u2192 binds GLP-1R on beta cells \u2192 Gs \u2192 cAMP \u2192 PKA \u2192 potentiates glucose-stimulated insulin secretion. Also inhibits glucagon, slows gastric emptying, promotes satiety.",
        "GIP": "Glucose-dependent insulinotropic polypeptide from K cells in duodenum. Potentiates insulin secretion. Also promotes adipose tissue triglyceride storage \u2014 links diet composition to fat deposition.",
        "GLP1_microbiome": "Gut microbiome SCFAs (propionate, butyrate) stimulate L cell GLP-1 secretion via GPR41/43 receptors. Dysbiosis \u2192 reduced SCFA \u2192 reduced GLP-1 \u2192 impaired insulin response \u2192 metabolic dysfunction pathway from gut to pancreas."
      },
      "carb_exhaustion_glycation": {
        "mechanism": "Chronic high dietary carbohydrate intake (especially refined carbs) leads to persistent hyperglycaemia and hyperinsulinaemia. This causes beta-cell exhaustion as the pancreas continuously overproduces insulin to compensate for peripheral insulin resistance. Over time, high glucose causes glucotoxicity via ROS production, damaging the beta cells and leading to Type 2 Diabetes.",
        "ref": "NUT_CARBS_001"
      }
    },
    "cross_system_connections": {
      "to_hair_system": "Hyperinsulinaemia \u2192 androgen excess (via reduced SHBG and ovarian androgen) \u2192 BIO_DERMALPAPILLA_001 miniaturisation and BIO_SEBGLAND_001 sebum overproduction",
      "to_digestive_system": "Exocrine function: all nutrient digestion depends on pancreatic enzyme secretion. Impaired exocrine \u2192 malabsorption \u2192 all nutrient deficiencies including for hair",
      "to_hormonal_system": "Insulin regulates SHBG (sex hormone binding globulin) production in liver \u2014 hyperinsulinaemia reduces SHBG \u2192 increases free testosterone \u2192 increased DHT \u2192 hair loss and acne",
      "to_microbiome": "GLP-1 is stimulated by gut microbiome SCFAs \u2014 gut health directly affects pancreatic hormone regulation"
    },
    "hormones_produced": [
      "HOR_INSULIN_001"
    ],
    "damage_pathways": {
