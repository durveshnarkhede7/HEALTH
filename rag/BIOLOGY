  "BIO_EPIDERMIS_001": {
    "id": "BIO_EPIDERMIS_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Epidermis",
    "parent_system": "SYS_SKIN_001",
    "definition": "The outermost multilayered stratified squamous epithelium of skin, 50 to 150 micrometers thick depending on body region. Forms the primary physical, chemical, immunological, and antimicrobial barrier between the body and the external environment. Maintained entirely by the continuous upward migration and terminal differentiation of basal layer stem cells.",
    "function": "Prevents transepidermal water loss (TEWL) via its lipid-rich stratum corneum barrier. Provides UV radiation absorption via melanin pigment. Detects and initiates immune responses via Langerhans cells. Provides tactile sensation via Merkel cells and free nerve ending interactions. Synthesises Vitamin D precursor upon UV exposure. Continuously self-renews every 28 to 40 days.",
    "layers_and_biology": {
      "stratum_basale": {
        "location": "Deepest layer, attached to basement membrane",
        "cells": "Keratinocyte stem cells (K5/K14 expressing) and melanocytes. Mitosis occurs here.",
        "division_rate": "Basal keratinocytes divide every 200 to 400 hours under normal conditions",
        "melanocyte_ratio": "1 melanocyte per 36 basal keratinocytes"
      },
      "stratum_spinosum": {
        "location": "Above basale. 4 to 8 cell layers thick",
        "cells": "Postmitotic keratinocytes connected by desmosomes (desmogleins and desmocollins)",
        "activity": "Desmosome formation provides mechanical strength. Lamellar granule biogenesis begins.",
        "Langerhans_cells": "Dendritic antigen-presenting cells from bone marrow origin reside here \u2014 2 to 4 percent of all epidermal cells. Detect pathogens and allergens."
      },
      "stratum_granulosum": {
        "location": "3 to 5 cell layers above spinosum",
        "cells": "Keratinocytes with keratohyalin granules (profilaggrin and loricrin \u2014 barrier proteins)",
        "activity": "Lamellar bodies exocytose their lipid cargo (ceramides, cholesterol, free fatty acids) into intercellular spaces \u2014 forming the lipid bilayer mortar of the stratum corneum. Tight junctions form here (claudin-1, claudin-4, occludin) creating a secondary molecular barrier."
      },
      "stratum_corneum": {
        "location": "Outermost 10 to 20 cell layers",
        "cells": "Completely anucleate corneocytes \u2014 dead, keratin-filled protein sacks",
        "architecture": "Brick and mortar structure \u2014 corneocytes are bricks embedded in intercellular lipid mortar",
        "lipid_composition": "Ceramides (40 to 50 percent), cholesterol (25 percent), free fatty acids (10 to 15 percent). This specific ratio is essential for barrier function.",
        "function": "Primary barrier to TEWL. Provides mechanical resistance. Maintains acidic pH via filaggrin degradation products (pyrrolidone carboxylic acid \u2014 NMF) and fatty acid secretion."
      }
    },
    "cellular_mechanism": "Keratinocyte stem cells in stratum basale divide asymmetrically \u2014 one cell remains as stem cell, one begins upward migration and differentiation. Over 28 to 40 days, cells progressively differentiate, changing keratin expression from K5/K14 (basal) to K1/K10 (suprabasal), accumulating filaggrin, loricrin, and cornified envelope proteins. At the granulosum-corneum transition, caspase-14 and other enzymes execute the terminal cornification programme \u2014 nucleus and organelles are dissolved, cell volume collapses, and the cell becomes a corneocyte.",
    "molecular_mechanism": {
      "barrier_lipid_synthesis": {
        "ceramide_synthesis": "Ceramides synthesised from sphingosine backbone + fatty acid by ceramide synthase enzymes in the ER \u2192 packaged into lamellar bodies in stratum spinosum \u2192 secreted at granulosum-corneum interface",
        "omega3_incorporation": "Omega-3 fatty acids (EPA, DHA) are incorporated into ceramide and phospholipid structures of the barrier. Higher omega-3 \u2192 more fluid, effective barrier \u2192 reduced TEWL. Deficiency \u2192 increased TEWL \u2192 dry, reactive skin. Ref: NUT_OMEGA3_001",
        "ceramide_deficiency_consequence": "Low ceramide content \u2192 porous barrier \u2192 TEWL increase \u2192 dry skin, eczema susceptibility, allergen entry, microbiome disruption"
      },
      "skin_pH_regulation": {
        "normal_pH": "4.5 to 5.5 \u2014 the acid mantle",
        "mechanism": "Filaggrin degradation products (NMF components: PCA, urocanic acid) acidify stratum corneum. Sebaceous fatty acid secretion contributes. Sodium/hydrogen antiporter activity in corneocytes maintains proton gradient.",
        "antimicrobial_significance": "Acidic pH inhibits S. aureus and P. aeruginosa colonisation. P. acnes prefers pH 6 to 6.5 \u2014 seborrhoea and alkaline shifts promote acne",
        "zinc_contribution": "Zinc inhibits alkaline phosphatase activity \u2014 helps maintain stratum corneum acidity. Ref: NUT_ZINC_001"
      },
      "filaggrin_critical_functions": {
        "barrier_protein": "Filaggrin aggregates keratin filaments in stratum corneum \u2192 dense keratin matrix \u2192 mechanical strength",
        "NMF_production": "Filaggrin proteolytic breakdown products form Natural Moisturising Factor (NMF) \u2014 pyrrolidone carboxylic acid, urocanic acid, amino acids \u2014 which bind water within corneocytes",
        "filaggrin_mutations": "Loss-of-function FLG gene mutations \u2192 severely impaired barrier \u2192 ichthyosis vulgaris, high atopic dermatitis risk \u2014 epigenetic example of genetic skin barrier compromise"
      },
      "innate_immune_layer": {
        "keratinocyte_AMP": "Keratinocytes synthesise antimicrobial peptides \u2014 beta-defensin-2, LL-37 (cathelicidin) \u2014 upon pattern recognition of microbial signals. These peptides directly kill bacteria by membrane disruption.",
        "Vitamin_D_AMP_induction": "1,25(OH)2 Vitamin D directly induces LL-37/cathelicidin gene expression in keratinocytes. Vitamin D deficiency \u2192 reduced AMP production \u2192 increased infection susceptibility. Ref: NUT_VITD_001",
        "zinc_AMP_support": "Zinc is required for beta-defensin synthesis and stability. Zinc deficiency \u2192 reduced cutaneous antimicrobial defence. Ref: NUT_ZINC_001"
      },
      "renewal_rate_regulation": {
        "normal": "28 to 40 days full turnover",
        "hypothyroid_slowing": "T3 receptors on basal keratinocytes \u2014 low T3 \u2192 reduced basal mitosis \u2192 turnover extends to 50 to 70 days \u2192 accumulation of desquamation backlog \u2192 dry, rough texture. Ref: HOR_THYROID_001",
        "cortisol_thinning": "Chronic glucocorticoid exposure \u2192 reduced basal layer proliferation \u2192 epidermal thinning \u2192 impaired barrier. Ref: HOR_CORTISOL_001"
      },
      "lipid_membrane_composition": {
        "mechanism": "The stratum corneum barrier heavily depends on the balance of saturated and unsaturated fats in ceramides and free fatty acids. High intake of trans fats or excessive omega-6 (from refined seed oils) creates rigid, pro-inflammatory lipid membranes, increasing TEWL (Transepidermal Water Loss). Conversely, adequate Omega-3 and healthy saturated fats maintain membrane fluidity and barrier integrity.",
        "ref": "NUT_FATS_001"
      }
