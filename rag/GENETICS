  "GEN_MTHFR_001": {
    "id": "GEN_MTHFR_001",
    "node_type": "genetics",
    "version": "1.0",
    "name": "MTHFR (Methylenetetrahydrofolate Reductase)",
    "mechanism": "The MTHFR enzyme is responsible for converting dietary folate (B9) into 5-Methyltetrahydrofolate (5-MTHF), the active form required for the methylation cycle, DNA synthesis, and homocysteine clearance.",
    "polymorphism_impact": "The C677T and A1298C variants (SNPs) reduce the enzyme's efficiency by 40% to 70%. Individuals with these variants cannot effectively process synthetic Folic Acid. Instead, unmetabolized folic acid builds up in the blood, blocking folate receptors, while the body simultaneously suffers from severe active folate deficiency.",
    "biological_consequences": [
      "Hyperhomocysteinemia: High homocysteine levels directly damage the endothelial lining of blood vessels, driving early-onset cardiovascular disease (massive in India).",
      "Neurotransmitter failure: Poor methylation impairs the synthesis of serotonin, dopamine, and melatonin (driving depression and insomnia).",
      "Impaired liver detoxification (Phase II methylation pathway)."
    ],
    "epigenetic_rescue": [
      "Strict avoidance of synthetic 'Folic Acid' (found in cheap supplements and fortified foods).",
      "Direct supplementation with L-Methylfolate (5-MTHF) and Methylcobalamin (B12) to bypass the broken enzyme.",
      "NUT_B2_001 (Riboflavin acts as a cofactor to speed up whatever residual MTHFR enzyme activity remains)."
    ],
    "related_nodes": ["NUT_FOLATE_001", "NUT_B12_001", "SYS_CARDIOMETABOLIC_001"]
  },
  "GEN_ANDROGEN_RECEPTOR_001": {
    "id": "GEN_ANDROGEN_RECEPTOR_001",
    "node_type": "genetics",
    "version": "1.0",
    "name": "AR Gene (Androgen Receptor - CAG Repeats)",
    "mechanism": "The AR gene is located on the X chromosome (inherited from the mother's side). It determines the structure and sensitivity of androgen receptors on cells, particularly in the dermal papilla of the hair follicle.",
    "polymorphism_impact": "The sensitivity of the receptor is inversely proportional to the number of CAG (cytosine-adenine-guanine) repeats in the gene. Fewer CAG repeats = a highly sensitive receptor that reacts aggressively to even normal or low levels of DHT.",
    "biological_consequences": [
      "This is the exact genetic mechanism of Androgenetic Alopecia (Male/Female Pattern Baldness). It explains why men with normal testosterone/DHT levels can go completely bald, while men with high testosterone/DHT can keep a full head of hair (they have high CAG repeats/low sensitivity).",
      "Increases susceptibility to severe hormonal acne and prostate enlargement."
    ],
    "epigenetic_rescue": [
      "Since you cannot change the receptor sensitivity, you must strictly control the ligand (DHT) binding to it.",
      "BSG_INSULIN_RESISTANCE_001 management (Insulin upregulates 5-alpha reductase, creating more DHT).",
      "Natural/Pharmaceutical DHT blockers (e.g., Saw Palmetto, Finasteride) to reduce the DHT load hitting the hypersensitive receptors."
    ],
    "related_nodes": ["HOR_DHT_001", "MED_ANDROGENETIC_ALOPECIA_001", "BIO_FOLLICLE_001"]
  },
