    "mechanism": {
      "nuclear_DNA": "Hydroxyl radicals attack guanine bases → 8-oxo-dG. If not repaired by base excision repair (BER) enzymes, this causes G→T transversion mutations. Zinc is essential for BER enzyme function.",
      "mitochondrial_DNA": "mtDNA has NO histone protection and sits directly adjacent to the ETC (the primary ROS source). mtDNA accumulates 10-20x more oxidative damage than nuclear DNA. mtDNA mutations → defective ETC proteins → more ROS → more mtDNA damage (the aging vicious cycle).",
      "telomere_damage": "Telomeres (chromosome end-caps) are guanine-rich sequences (TTAGGG repeats) — making them preferential targets for hydroxyl radicals. Oxidative stress accelerates telomere shortening → cellular senescence → biological aging."
    },
    "tissue_targets": [
      "BIO_MELANOCYTE_001 (Oxidative DNA damage depletes melanocyte stem cells → premature greying)",
      "BIO_FOLLICLE_001 (Stem cell DNA damage in the bulge region → follicle miniaturization)"
    ],
    "nutritional_connection": [
      "NUT_ZINC_001 (Essential for DNA repair enzymes — BER pathway)",
      "NUT_FOLATE_001 (Required for DNA methylation and repair)",
      "NUT_B12_001 (Protects methylation pathways that maintain DNA integrity)"
    ],
    "indian_context": "PM2.5 air pollution particles are small enough to enter cells and directly cause oxidative DNA damage. Indians in Delhi/NCR have measurably elevated 8-oxo-dG levels compared to rural populations."
  },
  "OXI_PROTEIN_OXIDATION_001": {
