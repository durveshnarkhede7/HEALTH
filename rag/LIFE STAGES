  "LFS_PREGNANCY_001": {
    "id": "LFS_PREGNANCY_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Pregnancy (The Incubator Phase)",
    "biological_shift": "The placenta takes over hormone production. Massive, sustained increases in Estrogen, Progesterone, and HCG. The immune system is heavily suppressed.",
    "metabolic_vulnerabilities": [
      "Gestational Insulin Resistance: The placenta secretes Human Placental Lactogen (hPL), which actively blocks the mother's insulin. This is a brilliant biological adaptation to keep glucose in the blood longer, so it crosses the placenta to feed the baby. If the mother eats a high-sugar diet, this crosses into Gestational Diabetes.",
      "Nutrient Parasitism: The fetus prioritizes its own survival over the mother. If the mother's diet lacks calcium, the fetus will literally dissolve the mother's bones and teeth to build its own skeleton. Severe depletion of DHA, Iron, Folate, and Choline is common.",
      "Immune Shift: The mother's immune system shifts from Th1 (cellular defense) to Th2 (antibody defense) to prevent her body from rejecting the genetically foreign fetus. Many women with autoimmune diseases (like Hashimoto's) suddenly feel 'cured' during pregnancy because of this suppression."
    ],
    "symptom_manifestation": [
      "Thick, lustrous hair (High estrogen locks all hair follicles in the anagen growth phase, zero shedding).",
      "SYM_FATIGUE_001",
      "SYM_WEIGHTGAIN_001"
    ],
    "related_nodes": ["BSG_INSULIN_RESISTANCE_001", "NUT_CALCIUM_001", "INF_AUTOIMMUNE_001"]
  },
  "LFS_POSTPARTUM_001": {
    "id": "LFS_POSTPARTUM_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Postpartum (The Hormonal Crash)",
    "biological_shift": "The delivery of the placenta triggers the most violent hormonal drop a human being will ever experience. Estrogen and Progesterone plummet 100-fold within 48 hours.",
    "metabolic_vulnerabilities": [
      "Postpartum Telogen Effluvium: Without the high estrogen to hold them in place, 30-50% of the hair follicles instantly enter the resting phase (Telogen). Exactly 3 to 4 months later, they all fall out simultaneously in massive clumps.",
      "Postpartum Thyroiditis: The immune system, which was suppressed for 9 months, aggressively rebounds (shifting back to Th1). In genetically susceptible women (HLA-DQ), this rebound triggers a violent autoimmune attack on the thyroid gland, often misdiagnosed as standard 'new mom fatigue'.",
      "Severe Nutrient Deficit: Lactation requires 500-700 extra calories a day and massive amounts of water, calcium, and protein. The mother is usually utterly depleted of Iron and B12."
    ],
    "symptom_manifestation": [
      "SYM_HAIRFALL_001 (Severe shedding at month 3-4)",
      "SYM_FATIGUE_001",
      "SYM_ANXIETY_001 (Postpartum depression driven by progesterone crash)"
    ],
    "related_nodes": ["MED_TELOGEN_EFFLUVIUM_001", "MED_HASHIMOTOS_001", "HOR_PROGESTERONE_001"]
  },
  "LFS_PERIMENOPAUSE_001": {
    "id": "LFS_PERIMENOPAUSE_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Perimenopause (The Chaotic Decade: Ages 40-50)",
    "biological_shift": "The ovaries begin to sputter and fail. They do not fail gracefully. Ovulation becomes erratic.",
    "metabolic_vulnerabilities": [
      "Estrogen Dominance: Because the woman is not ovulating every month, she produces zero Progesterone for that cycle. However, her ovaries are still wildly pumping out Estrogen (sometimes 2-3x normal levels). This creates a massive, unopposed ratio of Estrogen to Progesterone.",
      "Symptom Explosion: Without calming Progesterone (which converts to Allopregnanolone in the brain), the woman experiences severe anxiety, insomnia, rage, and heart palpitations. The high, unopposed Estrogen causes heavy, prolonged menstrual bleeding (fibroids) and tender breasts.",
      "Metabolic slowdown: Cortisol rises to compensate for the failing ovaries, driving visceral belly fat accumulation."
    ],
    "symptom_manifestation": [
      "SYM_ANXIETY_001",
      "SYM_POORSLEEP_001",
      "SYM_WEIGHTGAIN_001 (Specifically 'Meno-pot' belly fat)",
      "SYM_HAIRFALL_001 (Diffuse thinning)"
    ],
    "related_nodes": ["HOR_PROGESTERONE_001", "HOR_ESTROGEN_001", "STR_CHRONIC_001"]
  },
  "LFS_MENOPAUSE_001": {
    "id": "LFS_MENOPAUSE_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Menopause (The Estrogen Flatline: Age 50+)",
    "biological_shift": "Defined as 12 consecutive months without a period. The ovaries have completely shut down. Estrogen and Progesterone flatline. Testosterone (produced by the adrenals) remains.",
    "metabolic_vulnerabilities": [
      "Cardiovascular Shock: Estrogen is heavily cardioprotective (keeps blood vessels flexible) and insulin-sensitizing. When it vanishes, a woman's risk of heart attack instantly spikes to match a man's, and her insulin resistance skyrockets.",
      "Collagen Collapse: Estrogen is required for Fibroblasts to make collagen and hyaluronic acid. In the first 5 years of menopause, women lose 30% of their skin collagen. Skin becomes paper-thin, dry, and wrinkly. Hair shafts become brittle and snap easily.",
      "Androgen Dominance: With estrogen gone, the remaining adrenal testosterone is now unopposed. It converts to DHT, causing male-pattern hair loss (Androgenetic Alopecia) and facial hair growth in women."
    ],
    "symptom_manifestation": [
      "SYM_AGEING_001 (Rapid collagen loss)",
      "SYM_DRYSKIN_001",
      "SYM_THINHAIR_001",
      "Hot flashes (Hypothalamus screaming for estrogen)"
    ],
    "related_nodes": ["BIO_COLLAGEN_001", "MED_ANDROGENETIC_ALOPECIA_001", "SYS_CARDIOMETABOLIC_001"]
  },
  "LFS_ANDROPAUSE_001": {
    "id": "LFS_ANDROPAUSE_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Andropause (Male Aging: Age 45+)",
    "biological_shift": "Unlike menopause, male hormones do not crash overnight. Total Testosterone declines slowly (1-2% per year after age 30).",
    "metabolic_vulnerabilities": [
      "The SHBG Trap: As men age, the liver produces more Sex Hormone Binding Globulin (SHBG). SHBG binds to testosterone, rendering it biologically inactive. A 55-year-old man may have 'normal' Total Testosterone on a lab report, but his FREE (active) Testosterone is virtually zero.",
      "Aromatase Upregulation: As men gain visceral fat (due to insulin resistance), the fat cells produce the 'Aromatase' enzyme. Aromatase literally steals the man's remaining testosterone and converts it into Estrogen. This causes 'man-boobs' (gynecomastia), severe loss of libido, and depression."
    ],
    "symptom_manifestation": [
      "SYM_FATIGUE_001",
      "SYM_WEIGHTGAIN_001 (Belly fat)",
      "Loss of morning erections (classic sign of Free T crash)"
    ],
    "related_nodes": ["HOR_SHBG_001", "HOR_ESTROGEN_001", "HOR_TESTOSTERONE_001"]
  },
