  "BIO_EPIDERMIS_001": {
    "id": "BIO_EPIDERMIS_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Epidermis",
    "parent_system": "SYS_SKIN_001",
    "definition": "The outermost multilayered stratified squamous epithelium of skin, 50 to 150 micrometers thick depending on body region. Forms the primary physical, chemical, immunological, and antimicrobial barrier between the body and the external environment. Maintained entirely by the continuous upward migration and terminal differentiation of basal layer stem cells.",
    "function": "Prevents transepidermal water loss (TEWL) via its lipid-rich stratum corneum barrier. Provides UV radiation absorption via melanin pigment. Detects and initiates immune responses via Langerhans cells. Provides tactile sensation via Merkel cells and free nerve ending interactions. Synthesises Vitamin D precursor upon UV exposure. Continuously self-renews every 28 to 40 days.",
    "layers_and_biology": {
      "stratum_basale": {
        "location": "Deepest layer, attached to basement membrane",
        "cells": "Keratinocyte stem cells (K5/K14 expressing) and melanocytes. Mitosis occurs here.",
        "division_rate": "Basal keratinocytes divide every 200 to 400 hours under normal conditions",
        "melanocyte_ratio": "1 melanocyte per 36 basal keratinocytes"
      },
      "stratum_spinosum": {
        "location": "Above basale. 4 to 8 cell layers thick",
        "cells": "Postmitotic keratinocytes connected by desmosomes (desmogleins and desmocollins)",
        "activity": "Desmosome formation provides mechanical strength. Lamellar granule biogenesis begins.",
        "Langerhans_cells": "Dendritic antigen-presenting cells from bone marrow origin reside here — 2 to 4 percent of all epidermal cells. Detect pathogens and allergens."
      },
      "stratum_granulosum": {
        "location": "3 to 5 cell layers above spinosum",
        "cells": "Keratinocytes with keratohyalin granules (profilaggrin and loricrin — barrier proteins)",
        "activity": "Lamellar bodies exocytose their lipid cargo (ceramides, cholesterol, free fatty acids) into intercellular spaces — forming the lipid bilayer mortar of the stratum corneum. Tight junctions form here (claudin-1, claudin-4, occludin) creating a secondary molecular barrier."
      },
      "stratum_corneum": {
        "location": "Outermost 10 to 20 cell layers",
        "cells": "Completely anucleate corneocytes — dead, keratin-filled protein sacks",
        "architecture": "Brick and mortar structure — corneocytes are bricks embedded in intercellular lipid mortar",
        "lipid_composition": "Ceramides (40 to 50 percent), cholesterol (25 percent), free fatty acids (10 to 15 percent). This specific ratio is essential for barrier function.",
        "function": "Primary barrier to TEWL. Provides mechanical resistance. Maintains acidic pH via filaggrin degradation products (pyrrolidone carboxylic acid — NMF) and fatty acid secretion."
      }
    },
    "cellular_mechanism": "Keratinocyte stem cells in stratum basale divide asymmetrically — one cell remains as stem cell, one begins upward migration and differentiation. Over 28 to 40 days, cells progressively differentiate, changing keratin expression from K5/K14 (basal) to K1/K10 (suprabasal), accumulating filaggrin, loricrin, and cornified envelope proteins. At the granulosum-corneum transition, caspase-14 and other enzymes execute the terminal cornification programme — nucleus and organelles are dissolved, cell volume collapses, and the cell becomes a corneocyte.",
    "molecular_mechanism": {
      "barrier_lipid_synthesis": {
        "ceramide_synthesis": "Ceramides synthesised from sphingosine backbone + fatty acid by ceramide synthase enzymes in the ER → packaged into lamellar bodies in stratum spinosum → secreted at granulosum-corneum interface",
        "omega3_incorporation": "Omega-3 fatty acids (EPA, DHA) are incorporated into ceramide and phospholipid structures of the barrier. Higher omega-3 → more fluid, effective barrier → reduced TEWL. Deficiency → increased TEWL → dry, reactive skin. Ref: NUT_OMEGA3_001",
        "ceramide_deficiency_consequence": "Low ceramide content → porous barrier → TEWL increase → dry skin, eczema susceptibility, allergen entry, microbiome disruption"
      },
      "skin_pH_regulation": {
        "normal_pH": "4.5 to 5.5 — the acid mantle",
        "mechanism": "Filaggrin degradation products (NMF components: PCA, urocanic acid) acidify stratum corneum. Sebaceous fatty acid secretion contributes. Sodium/hydrogen antiporter activity in corneocytes maintains proton gradient.",
        "antimicrobial_significance": "Acidic pH inhibits S. aureus and P. aeruginosa colonisation. P. acnes prefers pH 6 to 6.5 — seborrhoea and alkaline shifts promote acne",
        "zinc_contribution": "Zinc inhibits alkaline phosphatase activity — helps maintain stratum corneum acidity. Ref: NUT_ZINC_001"
      },
      "filaggrin_critical_functions": {
        "barrier_protein": "Filaggrin aggregates keratin filaments in stratum corneum → dense keratin matrix → mechanical strength",
        "NMF_production": "Filaggrin proteolytic breakdown products form Natural Moisturising Factor (NMF) — pyrrolidone carboxylic acid, urocanic acid, amino acids — which bind water within corneocytes",
        "filaggrin_mutations": "Loss-of-function FLG gene mutations → severely impaired barrier → ichthyosis vulgaris, high atopic dermatitis risk — epigenetic example of genetic skin barrier compromise"
      },
      "innate_immune_layer": {
        "keratinocyte_AMP": "Keratinocytes synthesise antimicrobial peptides — beta-defensin-2, LL-37 (cathelicidin) — upon pattern recognition of microbial signals. These peptides directly kill bacteria by membrane disruption.",
        "Vitamin_D_AMP_induction": "1,25(OH)2 Vitamin D directly induces LL-37/cathelicidin gene expression in keratinocytes. Vitamin D deficiency → reduced AMP production → increased infection susceptibility. Ref: NUT_VITD_001",
        "zinc_AMP_support": "Zinc is required for beta-defensin synthesis and stability. Zinc deficiency → reduced cutaneous antimicrobial defence. Ref: NUT_ZINC_001"
      },
      "renewal_rate_regulation": {
        "normal": "28 to 40 days full turnover",
        "hypothyroid_slowing": "T3 receptors on basal keratinocytes — low T3 → reduced basal mitosis → turnover extends to 50 to 70 days → accumulation of desquamation backlog → dry, rough texture. Ref: HOR_THYROID_001",
        "cortisol_thinning": "Chronic glucocorticoid exposure → reduced basal layer proliferation → epidermal thinning → impaired barrier. Ref: HOR_CORTISOL_001"
      }
    },
    "cross_system_connections": {
      "to_hormonal_system": "HOR_THYROID_001 regulates renewal rate. HOR_CORTISOL_001 reduces basal mitosis. HOR_ESTROGEN_001 maintains epidermal thickness and hydration.",
      "to_digestive_system": "Gut dysbiosis (BIO_MICROBIOME_001) → systemic inflammation → impairs epidermal barrier (gut-skin axis)",
      "to_immune_system": "Langerhans cells here communicate directly with adaptive immunity — hapten sensitisation, allergen presentation, contact dermatitis initiation"
    },
    "damage_pathways": {
      "nutritional": ["NUT_VITC_001", "NUT_ZINC_001", "NUT_OMEGA3_001", "NUT_VITD_001"],
      "environmental": ["ENV_UV_001", "ENV_POLLUTION_001"],
      "inflammatory": ["INF_CHRONIC_001"],
      "oxidative": ["OXI_FREE_RADICAL_001"],
      "hormonal": ["HOR_THYROID_001", "HOR_CORTISOL_001"]
    },
    "recovery_pathways": {
      "nutritional": ["NUT_VITC_001", "NUT_ZINC_001", "NUT_OMEGA3_001"],
      "recovery_timeline": "REC_SKIN_001"
    },
    "tags": ["epidermis", "skin barrier", "stratum corneum", "ceramides", "TEWL", "filaggrin", "Langerhans cells", "desquamation", "acid mantle", "NMF", "keratinocytes", "omega-3", "Vitamin D"]
  },
  "BIO_DERMIS_001": {
    "id": "BIO_DERMIS_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Dermis",
    "parent_system": "SYS_SKIN_001",
    "sub_structures": ["BIO_COLLAGEN_001"],
    "definition": "The connective tissue layer between the epidermis and subcutaneous fat — 1 to 4 mm thick, comprising 90 percent of skin thickness. Houses the structural protein matrix (collagen, elastin), the vascular supply network for skin, sensory nerve endings, hair follicle roots, sebaceous glands, eccrine sweat glands, and the fibroblasts that produce and maintain the extracellular matrix.",
    "function": "Provides tensile strength and elasticity via collagen and elastin networks. Supplies the avascular epidermis with all nutrients via capillary diffusion. Senses temperature, pressure, pain, and touch via specialised receptors. Generates the structural scaffold within which hair follicles operate. Regulates skin hydration through glycosaminoglycan water retention.",
    "layers": {
      "papillary_dermis": "Loose connective tissue immediately below epidermis. Contains fine collagen type III fibrils, rich capillary loops (papillary loops) that nourish epidermis, and free nerve endings. Site of immediate immune responses.",
      "reticular_dermis": "Deeper, denser layer with thick interwoven type I collagen bundles, elastin fibres, and fewer cells. Provides the primary mechanical strength of skin."
    },
    "cellular_mechanism": "Fibroblasts are the dominant cell type — they produce and continuously remodel collagen, elastin, fibronectin, and glycosaminoglycans. Fibroblast activity is regulated by mechanical tension (low tension → reduced collagen synthesis — explaining skin laxity after weight loss), growth factors (TGF-beta-1 stimulates collagen), and hormones (estrogen maintains fibroblast activity; cortisol suppresses it). Mast cells in the dermis mediate allergic and inflammatory responses. Dendritic cells participate in immune surveillance.",
    "molecular_mechanism": {
      "collagen_remodelling": "Collagen synthesis by fibroblasts is balanced against degradation by matrix metalloproteinases (MMP-1, MMP-3, MMP-9). UV radiation activates AP-1 transcription factor → MMP-1 upregulation → collagen degradation. Cortisol reduces TGF-beta-1-driven collagen synthesis AND increases MMP expression → net collagen loss. For full collagen synthesis pathway see BIO_COLLAGEN_001.",
      "elastin_network": {
        "structure": "Elastin fibres are crosslinked polymers of tropoelastin monomers by lysyl oxidase (copper-dependent enzyme)",
        "function": "Provides rapid elastic recoil — skin returns to shape after deformation. Elastin molecules can stretch to 150 percent of resting length.",
        "degradation": "Elastin is not regenerated efficiently after age 30. UV-induced elastases (MMP-12) degrade elastin → solar elastosis — permanently damaged elastin seen as leathery, furrowed skin in sun-damaged areas",
        "copper_dependency": "Lysyl oxidase requires copper for crosslinking both elastin and collagen. Copper deficiency → uncrosslinked, fragile fibres. Ref: NUT_COPPER_001"
      },
      "glycosaminoglycan_water_retention": {
        "hyaluronic_acid": "The major GAG of dermis. 1g HA holds up to 6 litres water. Produced by fibroblasts via HAS (hyaluronan synthase) enzymes.",
        "HA_degradation": "Hyaluronidase enzymes and ROS degrade HA. UV exposure → ROS → HA degradation → reduced dermal hydration → wrinkle formation",
        "estrogen_regulation": "Estrogen upregulates HAS gene expression and reduces hyaluronidase activity. Estrogen decline at menopause → rapid HA reduction → dry, thin skin. Ref: HOR_ESTROGEN_001"
      },
      "AGE_formation": {
        "process": "Blood glucose non-enzymatically attaches to collagen lysine and arginine residues → Maillard reaction → Schiff base → Amadori products → advanced glycation end products (AGEs)",
        "consequences": "AGEs form irreversible crosslinks between collagen fibres → rigid, yellow, mechanically compromised matrix. AGE-RAGE receptor binding → NF-kB → inflammatory cytokines → further matrix degradation → accelerated skin ageing",
        "insulin_resistance_link": "BLD_INSULIN_RESISTANCE_001 maintains chronically elevated glucose → faster AGE accumulation. Even postprandial glucose spikes contribute cumulatively over years."
      }
    },
    "cross_system_connections": {
      "to_energy_system": "Fibroblast ATP requirements for collagen synthesis — impaired by BIO_MITOCHONDRIA_001 dysfunction",
      "to_hormonal_system": "HOR_ESTROGEN_001 maintains HA and fibroblast activity. HOR_CORTISOL_001 suppresses both. HOR_INSULIN_001 excess drives AGE formation.",
      "to_metabolic_system": "BLD_INSULIN_RESISTANCE_001 → AGE-mediated collagen crosslinking is the metabolic pathway to premature skin ageing"
    },
    "damage_pathways": {
      "nutritional": ["NUT_VITC_001", "NUT_PROTEIN_001", "NUT_ZINC_001", "NUT_COPPER_001"],
      "hormonal": ["HOR_CORTISOL_001", "HOR_ESTROGEN_001"],
      "environmental": ["ENV_UV_001"],
      "oxidative": ["OXI_FREE_RADICAL_001"],
      "glycation": "BLD_INSULIN_RESISTANCE_001",
      "aging": "LIF_AGING_001"
    },
    "recovery_pathways": {
      "nutritional": ["NUT_VITC_001", "NUT_PROTEIN_001", "NUT_ZINC_001"],
      "recovery_timeline": "REC_SKIN_001"
    },
    "tags": ["dermis", "fibroblasts", "extracellular matrix", "hyaluronic acid", "elastin", "MMPs", "AGEs", "glycation", "skin ageing", "collagen remodelling", "glycosaminoglycans"]
  },
  "BIO_COLLAGEN_001": {
    "id": "BIO_COLLAGEN_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Collagen Network",
    "parent_system": "SYS_SKIN_001",
    "parent_structure": "BIO_DERMIS_001",
    "definition": "The most abundant protein in the human body — comprising 25 to 35 percent of total body protein. Collagen is a family of 28 distinct types (Type I through XXVIII) that form the fibrous structural scaffold of skin, bone, tendon, cartilage, and blood vessels. In skin, Type I and III are primary; in hair follicle basement membrane, Type IV is critical.",
    "function": "Provides mechanical tensile strength and structural integrity. In skin: resists tearing and stretching forces, forms the architectural framework of the dermis, supports wound healing by providing scaffold for cell migration. In bone: organic framework for hydroxyapatite mineralisation. In hair follicle: Type IV collagen basement membrane anchors follicle and supports dermal papilla.",
    "types_in_healthsync_scope": {
      "type_I": "Most abundant. Found in dermis, tendon, bone cortex, cornea, blood vessel walls. Provides tensile strength. 2 alpha-1 chains + 1 alpha-2 chain.",
      "type_III": "Found with Type I in skin, blood vessels, and uterus. Higher proportion in fetal skin — more elastic. Important in wound healing initial matrix.",
      "type_IV": "Non-fibrillar. Forms sheet-like basement membranes — hair follicle, skin, glomerulus. Scaffold for epithelial-mesenchymal organisation.",
      "type_XVII": "Transmembrane — anchors basal keratinocytes to the basement membrane via hemidesmosomes. Mutations cause epidermolysis bullosa."
    },
    "synthesis_pathway": {
      "step_1_transcription": "TGF-beta-1 → SMAD2/3 pathway → activates COL1A1 and COL1A2 gene promoters in fibroblast nucleus → mRNA transcription. Zinc-dependent RNA Pol II essential. Ref: NUT_ZINC_001",
      "step_2_translation": "Ribosomes translate mRNA → pre-pro-alpha chains. Requires glycine (every third amino acid in collagen sequence is glycine), proline, and lysine — from dietary protein. Ref: NUT_PROTEIN_001",
      "step_3_hydroxylation": "Prolyl-4-hydroxylase converts proline → 4-hydroxyproline. STRICT requirement for both Vitamin C (ascorbate as electron donor) and Fe2+ as cofactor. Without Vitamin C: enzyme cannot complete catalytic cycle → unhydroxylated procollagen accumulates → cannot form stable triple helix → degraded. This is the biochemical basis of scurvy. Ref: NUT_VITC_001",
      "step_4_glycosylation": "Hydroxylysine residues glycosylated in ER by glucosyltransferase — required for subsequent fibril assembly",
      "step_5_triple_helix": "Three hydroxylated pro-alpha chains wind together in C→N direction forming right-handed triple helix — procollagen. Heat stable to 39°C — explains why fever can temporarily impair collagen.",
      "step_6_secretion": "Procollagen secreted via Golgi apparatus into extracellular space",
      "step_7_cleavage": "N- and C-terminal propeptide extensions cleaved by procollagen proteases → tropocollagen",
      "step_8_fibril_assembly": "Tropocollagen monomers self-assemble in staggered array → collagen fibril",
      "step_9_crosslinking": "Lysyl oxidase (copper-dependent enzyme) oxidises lysine and hydroxylysine residues → aldehyde groups → spontaneous crosslinking between fibrils → mature collagen fibre with full tensile strength. Ref: NUT_COPPER_001"
    },
    "degradation_mechanisms": {
      "MMP_system": "Matrix metalloproteinases (MMP-1/collagenase, MMP-3/stromelysin, MMP-9/gelatinase) cleave collagen at specific sites. Balanced by TIMP inhibitors. Net collagen = synthesis minus MMP degradation.",
      "MMP_inducers": "UV radiation → AP-1 transcription factor → MMP-1 expression. Cortisol → reduces TIMP → MMP dominance. Inflammation (TNF-alpha, IL-1) → NF-kB → MMP upregulation.",
      "AGE_crosslinking": "Non-enzymatic glucose attachment to collagen lysine/arginine → AGEs → rigid crosslinks different from enzymatic lysyl oxidase crosslinks. AGE-modified collagen cannot be remodelled by MMPs normally → accumulates as stiff, yellow, dysfunctional matrix.",
      "production_decline": "Fibroblast collagen synthesis declines approximately 1 percent per year from age 25. UV accelerates this decline further."
    },
    "cross_system_connections": {
      "to_energy_system": "BIO_MITOCHONDRIA_001 provides ATP for fibroblast collagen synthesis. Mitochondrial dysfunction reduces synthesis rate.",
      "to_metabolic_system": "BLD_INSULIN_RESISTANCE_001 → AGE formation in collagen — the direct metabolic mechanism of premature skin ageing.",
      "to_hormonal_system": "HOR_ESTROGEN_001 stimulates TGF-beta-1 driven collagen synthesis. HOR_CORTISOL_001 suppresses it. Explains rapid skin thinning post-menopause and with corticosteroid use."
    },
    "synthesis_requirements_refs": ["NUT_VITC_001", "NUT_PROTEIN_001", "NUT_ZINC_001", "NUT_COPPER_001", "NUT_IRON_001"],
    "damage_pathways": {
      "nutritional_depletion": ["NUT_VITC_001", "NUT_PROTEIN_001", "NUT_COPPER_001"],
      "hormonal": ["HOR_CORTISOL_001"],
      "oxidative": ["OXI_FREE_RADICAL_001"],
      "glycation": "BLD_INSULIN_RESISTANCE_001",
      "environmental": ["ENV_UV_001"],
      "aging": "LIF_AGING_001"
    },
    "recovery_pathways": {
      "nutritional": ["NUT_VITC_001", "NUT_PROTEIN_001", "NUT_ZINC_001", "NUT_COPPER_001"],
      "timeline": "New collagen fibres reach mechanical maturity at 3 to 6 months. Visual skin improvement precedes mechanical improvement."
    },
    "tags": ["collagen", "fibroblasts", "Vitamin C", "prolyl hydroxylase", "lysyl oxidase", "copper", "AGEs", "glycation", "MMP", "triple helix", "crosslinking", "wound healing", "Type I III IV"]
  },
  "BIO_SEBGLAND_001": {
    "id": "BIO_SEBGLAND_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Sebaceous Gland",
    "parent_system": "SYS_SKIN_001",
    "associated_with": "BIO_FOLLICLE_001",
    "definition": "Branched holocrine exocrine glands attached to the upper segment of the pilosebaceous unit, present across almost all body skin except palms and soles. Highest density on the face (400 to 900 per cm2 on forehead and nose), scalp, chest, and upper back — precisely the anatomical distribution of acne.",
    "function": "Secretes sebum — a complex lipid mixture — onto the skin surface and into the follicle. Sebum lubricates the hair shaft and skin, prevents transepidermal water loss from the follicle canal, maintains acid mantle pH, and provides antimicrobial protection via squalene and free fatty acids. Acts as a local paracrine signalling system — sebocytes produce neuropeptides and cytokines that influence neighbouring keratinocytes and follicle cells.",
    "cellular_mechanism": "Sebocytes are the specialised lipid-producing cells of the gland. They originate from sebaceous stem cells (CD34+/Blimp1+ expressing) at the gland periphery. As sebocytes mature they fill progressively with lipid droplets — visible on histology as vacuolated cells. At full maturation the sebocyte ruptures and releases its entire cytoplasmic contents — including the nucleus — as sebum. This holocrine secretion differentiates sebaceous glands from merocrine (eccrine) glands which secrete by exocytosis. Full sebocyte lifespan from stem cell to secretion is approximately 7 days.",
    "sebum_composition": {
      "triglycerides": "57 percent of total sebum",
      "wax_esters": "26 percent — unique to sebaceous secretion, not found elsewhere in body",
      "squalene": "12 percent — antioxidant precursor to cholesterol. When oxidised by UV, squalene peroxide is highly comedogenic",
      "free_fatty_acids": "5 percent — result of P. acnes lipase acting on triglycerides",
      "cholesterol_and_esters": "Remainder — structural and barrier components"
    },
    "molecular_mechanism": {
      "androgen_regulation": {
        "primary_driver": "Sebaceous glands are among the most androgen-sensitive tissues in the body. Sebocytes express androgen receptor (AR), 5-alpha reductase type 1 (converts testosterone to DHT locally), and 17beta-HSD enzymes for local androgen metabolism.",
        "signalling_cascade": "DHT or testosterone binds AR → AR nuclear translocation → binds androgen response elements → activates SREBP-1c (master lipogenic transcription factor) → upregulates FASN (fatty acid synthase), ACC (acetyl-CoA carboxylase), DGAT (diacylglycerol acyltransferase) → massive increase in fatty acid and triglyceride synthesis → sebum volume increases up to 5-fold",
        "DHT_potency": "DHT is 3 to 5 times more potent than testosterone at sebocyte AR — because DHT binds AR with higher affinity (Kd approximately 0.2 nM vs 1 nM for testosterone) and dissociates more slowly",
        "ref": "HOR_DHT_001"
      },
      "insulin_IGF1_pathway": {
        "mechanism": "Insulin and IGF-1 activate PI3K/Akt/mTORC1 independently of AR → mTORC1 phosphorylates SREBP-1 → same downstream lipogenesis as androgen pathway. Insulin and DHT therefore have additive sebum-stimulating effects.",
        "high_GI_diet_effect": "Dietary refined carbohydrates → glucose spike → insulin surge → IGF-1 elevation → sebocyte mTORC1 activation → sebum overproduction → acne. This explains the robust acne-diet relationship observed in epidemiological studies.",
        "ref": "HOR_INSULIN_001"
      },
      "acne_pathogenesis_cascade": {
        "step_1_sebum": "Androgen + insulin/IGF-1 driven sebum overproduction — follicle canal fills with sebum",
        "step_2_hyperkeratosis": "Androgen and IGF-1 also promote follicular keratinocyte proliferation and reduce normal desquamation → shed keratinocytes accumulate in follicle canal instead of being shed outward → microcomedone formation",
        "step_3_P_acnes": "Cutibacterium acnes (P. acnes) is an anaerobic commensal resident of the follicle. Excess sebum provides unlimited substrate → P. acnes proliferation within the blocked follicle → lipase enzyme converts sebum triglycerides to pro-inflammatory free fatty acids",
        "step_4_innate_immune": "Free fatty acids and P. acnes cell wall components (DAMPs and PAMPs) → activate TLR-2 and TLR-4 on surrounding keratinocytes and sebocytes → MyD88 signalling → NF-kB → IL-1beta, IL-6, IL-8, TNF-alpha secretion → neutrophil recruitment → inflammatory papule and pustule formation",
        "step_5_adaptive_immune": "CD4+ Th17 cells recognise P. acnes antigens → IL-17 → further keratinocyte inflammation and barrier disruption → nodular and cystic lesions in severe acne"
      },
      "gut_microbiome_connection": {
        "mechanism": "Gut dysbiosis → increased systemic LPS → TLR-4 on sebocytes and keratinocytes → basal NF-kB activation → lower threshold for inflammatory acne cascade",
        "ref": "BIO_MICROBIOME_001"
      }
    },
    "underactivity_consequences": {
      "dry_scalp_brittle_hair": "Insufficient sebum → follicle canal dry → hair shaft lacks lubrication → increased breakage and brittleness",
      "dry_skin": "Reduced sebum contribution to acid mantle → impaired barrier → increased TEWL",
      "trigger": "Isotretinoin (vitamin A analogue) reduces sebaceous gland activity by 90 percent — both therapeutic and dry skin side effect"
    },
    "cross_system_connections": {
      "to_hormonal_system": "Primary regulatory target of HOR_DHT_001 and HOR_INSULIN_001. Also responds to HOR_ESTROGEN_001 (anti-sebogenic) and HOR_CORTISOL_001 (increases local androgen conversion).",
      "to_digestive_system": "Gut microbiome dysbiosis (BIO_MICROBIOME_001) increases systemic inflammation → lowers threshold for inflammatory acne cascade.",
      "to_metabolic_system": "BLD_INSULIN_RESISTANCE_001 → chronic hyperinsulinaemia → persistent mTORC1 activation in sebocytes → chronic sebum excess."
    },
    "damage_pathways": {
      "hormonal_overactivation": ["HOR_DHT_001", "HOR_INSULIN_001"],
      "inflammatory": ["INF_CHRONIC_001"],
      "gut_mediated": ["GUT_DYSBIOSIS_001"]
    },
    "recovery_pathways": {
      "dht_reduction": ["NUT_ZINC_001"],
      "insulin_normalisation": "BLD_INSULIN_RESISTANCE_001",
