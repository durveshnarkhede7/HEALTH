  "EXE_RESISTANCE_001": {
    "id": "EXE_RESISTANCE_001",
    "node_type": "exercise",
    "version": "1.0",
    "name": "Resistance / Strength Training",
    "definition": "Exercise that causes muscles to contract against an external resistance (weights, bands, bodyweight) with the expectation of increases in strength, mass, and/or endurance.",
    "indian_context": "Increasingly popular in urban gyms, though culturally often secondary to walking/yoga. Critical for combating India's high rates of sarcopenia and osteopenia.",
    "biological_impacts": {
      "hormonal": [
        "HOR_TESTOSTERONE_001 (Acute post-workout spike)",
        "HOR_GH_001 (Massive release during deep sleep following workout)",
        "HOR_INSULIN_001 (Dramatically improves insulin sensitivity)"
      ],
      "cellular": [
        "BIO_MUSCLE_001 (Myofibrillar hypertrophy, increased glycogen storage capacity)",
        "BIO_BONE_001 (Mechanical loading stimulates osteoblasts, increasing density)"
      ],
      "systemic": [
        "SYS_METABOLIC_001 (Increases Basal Metabolic Rate by adding metabolically active tissue)"
      ]
    },
    "synergies": ["EXE_AEROBIC_001 (Concurrent training is optimal for longevity)"],
    "contraindications": [
      "STR_PHYSICAL_001 (Can worsen severe overtraining/burnout)",
      "SYM_JOINTPAIN_001 (If form is poor or load exceeds tissue tolerance)"
    ],
    "nutrient_demands": [
      "NUT_PROTEIN_001 (Crucial for muscle protein synthesis)",
      "NUT_MAGNESIUM_001 (Required for muscle relaxation and ATP production)",
      "NUT_ZINC_001"
    ],
    "symptom_relief": ["SYM_FATIGUE_001", "SYM_WEIGHTGAIN_001", "SYM_MUSCLEWEAKNESS_001"]
  },
