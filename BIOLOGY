    "structure": "Skeletal Muscle Tissue",
    "parent_system": "SYS_MUSCULOSKELETAL_001",
    "definition": "Voluntary striated muscle tissue attached to the skeleton via tendons, comprising 30 to 40 percent of total body mass in non-obese adults and representing the largest single tissue compartment. Skeletal muscle is simultaneously a locomotor organ, the primary insulin-responsive metabolic tissue (accounts for 75 to 80 percent of postprandial glucose disposal), and an active endocrine organ secreting myokines with systemic effects.",
    "function": "Force generation and movement via actin-myosin cross-bridge cycling. Glycogen storage — 300 to 400 grams — largest glycogen depot in the body. Insulin-stimulated glucose uptake — GLUT4 translocation. Amino acid reservoir — can release amino acids during fasting or stress (via protein catabolism) for gluconeogenesis. Endocrine signalling via myokines. Thermoregulation via shivering and non-shivering thermogenesis.",
    "fibre_types": {
      "type_I_slow_twitch": "Fatigue-resistant. Dense mitochondria. Primarily oxidative metabolism. Recruited for sustained low-intensity activity. High myoglobin content — appears red.",
      "type_IIa_fast_oxidative": "Intermediate. Moderate mitochondria. Mixed oxidative-glycolytic. Recruited for moderate-intensity sustained exercise.",
      "type_IIx_fast_glycolytic": "Fatigue rapidly. Few mitochondria. Primarily anaerobic glycolysis. Recruited for maximal power output. Appears pale."
    },
    "cellular_mechanism": "Skeletal muscle fibres are post-mitotic multinucleated syncytia — formed by fusion of many myoblasts. They cannot undergo conventional cell division. Muscle growth (hypertrophy) occurs by adding myofibrils (protein filaments) to existing fibres. Muscle regeneration after injury is performed by satellite cells (muscle stem cells — Pax7+ cells) that activate, proliferate, and fuse to form new fibres or repair damaged ones.",
    "molecular_mechanism": {
      "contraction_mechanism": {
        "sliding_filament": "Neural stimulation → ACh release → sarcolemma depolarisation → T-tubule → sarcoplasmic reticulum Ca2+ release → Ca2+-troponin C binding → tropomyosin shifts → actin active site exposed → myosin S1 head binds actin → power stroke (ATP hydrolysis → ADP+Pi → myosin conformational change → filament sliding) → muscle shortening",
        "ATP_requirement": "Each cross-bridge cycle consumes 1 ATP. A 100m sprint utilises approximately 25 mmol ATP in 10 seconds — met entirely by PCr hydrolysis and anaerobic glycolysis"
      },
      "insulin_glucose_uptake": {
        "signalling": "Insulin binds IR → IRS-1 phosphorylation → PI3K → PIP3 → PDK1 → Akt phosphorylation (Thr308, Ser473) → AS160 (Rab-GAP) phosphorylation → Rab10 GTPase activation → GLUT4 vesicle translocation to plasma membrane → GLUT4 insertion → facilitated glucose transport",
        "exercise_independent_pathway": "Muscle contraction → AMP:ATP ratio rises → AMPK activation → AMPK phosphorylates TBC1D4 and TBC1D1 (Rab-GAPs) → GLUT4 translocation via Rab8 → insulin-independent glucose uptake. This is why exercise reduces blood glucose even in severe insulin resistance.",
        "insulin_resistance_mechanism": "Ceramide and diacylglycerol accumulation (from saturated fat excess, obesity) → serine phosphorylation of IRS-1 (instead of tyrosine) → IRS-1 becomes inhibitory substrate → downstream signalling impaired → GLUT4 translocation reduced → glucose remains in bloodstream",
        "muscle_mass_significance": "Each kg of skeletal muscle contains approximately 120g GLUT4 protein. More muscle mass → more GLUT4 → more insulin-mediated glucose clearance → better insulin sensitivity — this is the physiological basis of resistance training for metabolic health"
      },
      "protein_synthesis_mTOR": {
        "pathway": "Resistance exercise + dietary leucine → PI3K/Akt → mTORC1 activation → 4E-BP1 phosphorylation (releases eIF4E) + S6K1 phosphorylation → increased mRNA translation initiation → muscle protein synthesis",
        "leucine_threshold": "2 to 3g leucine per meal required to maximally activate mTORC1 for muscle protein synthesis — equivalent to approximately 25 to 35g quality protein",
        "protein_turnover": "Muscle protein continuously synthesised and degraded. Net positive balance (synthesis exceeds breakdown) = hypertrophy. Net negative = atrophy. IGF-1 promotes synthesis, cortisol promotes breakdown (proteolysis)."
      },
      "myokine_secretion": {
        "IL6_muscle": "During and after exercise → muscle-derived IL-6 (different from inflammatory IL-6) → inhibits TNF-alpha, stimulates IL-10 (anti-inflammatory), promotes fat oxidation in adipose and liver, stimulates GLP-1 secretion from gut L cells",
        "irisin": "Exercise → PGC-1alpha activation → FNDC5 expression → cleaved to irisin → secreted. Irisin → promotes white adipose tissue browning (increased UCP1) → increased thermogenesis. Also crosses blood-brain barrier → BDNF expression → neuroplasticity and cognitive function.",
        "IL15": "Produced by muscle during contractions → promotes fat-free mass, reduces adipose tissue. Acts via TRAF6-dependent pathway. Anabolic effect independent of testosterone.",
        "BDNF": "Muscle produces BDNF during exercise → released into circulation → crosses BBB → hippocampal neurogenesis → improved memory and mood",
        "FGF21": "Produced during fasting or exercise → improves glucose and fatty acid metabolism, increases adiponectin, reduces hepatic lipogenesis"
      },
      "mitochondrial_biogenesis": {
        "PGC1alpha": "Exercise → AMPK and CaMKII activation → PGC-1alpha transcription and activation → nuclear translocation → coactivates NRF1, NRF2, TFAM → mitochondrial biogenesis genes transcribed → new mitochondria formed",
        "result": "Chronic aerobic exercise → 2 to 4 fold increase in muscle mitochondrial density → increased oxidative capacity → improved insulin sensitivity → reduced systemic metabolic disease risk"
      }
    },
    "cross_system_connections": {
      "to_metabolic_system": "Primary site of insulin-stimulated glucose disposal (BLD_INSULIN_RESISTANCE_001). Muscle mass is the most modifiable factor in insulin sensitivity.",
      "to_energy_system": "Muscle mitochondria (BIO_MITOCHONDRIA_001) density determines aerobic capacity and metabolic rate",
      "to_hormonal_system": "IGF-1 (HOR_IGF1_001) drives muscle protein synthesis. Cortisol (HOR_CORTISOL_001) drives muscle protein breakdown.",
      "to_brain": "Myokines (irisin, BDNF, IL-6) communicate exercise status to brain and adipose tissue"
    },
    "damage_pathways": {
      "nutritional": ["NUT_PROTEIN_001", "NUT_VITD_001", "NUT_MAGNESIUM_001"],
      "hormonal": ["HOR_CORTISOL_001"],
      "lifestyle": "Physical inactivity — each week of complete bed rest loses approximately 1 percent of muscle mass",
      "aging": "LIF_AGING_001"
    },
    "recovery_pathways": {
      "nutritional": ["NUT_PROTEIN_001", "NUT_VITD_001"],
      "exercise": "EXE_RESISTANCE_001",
      "sleep": "SLP_DEEPSLEEP_001"
    },
    "tags": ["skeletal muscle", "GLUT4", "insulin sensitivity", "myokines", "irisin", "IL-6", "IL-15", "BDNF", "mTOR", "leucine", "satellite cells", "PGC-1alpha", "mitochondrial biogenesis", "AMPK", "Type I II fibres", "muscle protein synthesis"]
  },
  "BIO_BONE_001": {
    "id": "BIO_BONE_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Bone Tissue",
    "parent_system": "SYS_MUSCULOSKELETAL_001",
    "definition": "Dynamic mineralised connective tissue composed of a Type I collagen organic matrix (osteoid) mineralised with hydroxyapatite crystals [Ca10(PO4)6(OH)2]. Bone comprises approximately 12 to 15 percent of body weight. Far from inert, bone undergoes continuous remodelling throughout life — approximately 10 percent of the skeleton is replaced annually. Bone is also an endocrine organ secreting osteocalcin, osteocrin, and lipocalin-2 that regulate systemic metabolism.",
    "function": "Structural support and organ protection. Mineral reservoir — stores 99 percent of body calcium, 85 percent of phosphorus, 50 percent of magnesium. Haematopoiesis — red bone marrow in axial skeleton and proximal long bones produces all blood cells. Endocrine function: osteocalcin (improves insulin sensitivity, testosterone production, and memory). Acid-base buffer during acidosis. Mechanical force transduction via Wolff's Law — bone adapts its architecture to habitual loading forces.",
    "bone_architecture": {
      "cortical_bone": "Dense outer shell — 80 percent of bone mass. Haversian canals with blood vessels. Primarily provides structural strength. Slow turnover rate.",
      "trabecular_bone": "Spongy inner network — 20 percent of bone mass but 80 percent of surface area. High turnover. Metabolically active. First to show osteoporotic changes. Present in vertebrae, pelvis, femoral neck.",
      "periosteum": "Dense connective tissue sheath on outer bone surface. Contains osteoprogenitor cells, blood vessels, and sensory nerves. Site of appositional growth and periosteal remodelling."
    },
    "cellular_mechanism": {
      "osteoblasts": {
        "origin": "Mesenchymal stem cells → pre-osteoblasts → osteoblasts. Runx2 is the master osteoblast transcription factor.",
        "function": "Synthesise Type I collagen osteoid matrix. Mineralise osteoid by secreting matrix vesicles containing calcium and phosphate → hydroxyapatite nucleation. Produce osteocalcin, osteopontin, bone sialoprotein.",
        "lifespan": "12 to 100 days. After completing bone matrix formation, osteoblasts either undergo apoptosis, become bone-lining cells, or become embedded in matrix as osteocytes."
      },
      "osteoclasts": {
        "origin": "Monocyte/macrophage lineage → RANKL stimulation → osteoclast precursor fusion → multinucleated osteoclast (2 to 50 nuclei)",
        "function": "Resorb mineralised bone by creating an acidic sealed compartment under the ruffled border → HCl dissolves mineral → cathepsin K enzyme degrades collagen matrix → bone degradation products released into circulation",
        "regulation": "RANK/RANKL/OPG axis: RANKL (on osteoblasts) binds RANK (on osteoclast precursors) → osteoclast differentiation. OPG (osteoprotegerin — decoy receptor secreted by osteoblasts) blocks RANKL → inhibits osteoclastogenesis. Estrogen increases OPG, decreases RANKL. Estrogen loss → imbalance → osteoclast dominance."
      },
      "osteocytes": {
        "definition": "Osteoblasts embedded in mineralised matrix — most abundant bone cell (90 to 95 percent). Connected via canalicular network of dendritic processes.",
        "function": "Mechanosensation — detect mechanical loading and fluid flow through canaliculi → signal osteoblasts to increase bone formation in loaded areas (Wolff's Law). Produce sclerostin (inhibits osteoblast Wnt signalling) and FGF23 (regulates phosphate balance). Orchestrate remodelling by directing both osteoblast and osteoclast activity."
      }
    },
    "molecular_mechanism": {
      "hydroxyapatite_mineralisation": {
        "calcium_phosphate": "Osteoblast secretes matrix vesicles containing high calcium and phosphate concentrations + alkaline phosphatase → cleaves phosphate esters → local Pi supersaturation → hydroxyapatite nucleation within vesicles → crystal growth into surrounding osteoid",
        "Vitamin_D_calcium_delivery": "1,25(OH)2D (calcitriol) upregulates calbindin-D28k and TRPV6 in duodenal enterocytes → increases calcium absorption efficiency 40-fold. Vitamin D deficiency → reduced calcium absorption → PTH elevation → PTH drives osteoclastic bone resorption to maintain serum calcium → net bone loss despite adequate dietary calcium. Ref: NUT_VITD_001",
        "Type_I_collagen_scaffold": "Mineralisation can only occur on an organised collagen scaffold. Collagen synthesis requires NUT_VITC_001 and NUT_PROTEIN_001. Defects in collagen → impaired mineralisation. Ref: BIO_COLLAGEN_001"
      },
      "RANKL_OPG_axis": {
        "normal": "Osteoblasts produce both RANKL (promotes osteoclasts) and OPG (inhibits osteoclasts). Balanced → coupled remodelling.",
        "estrogen_effect": "Estrogen → increases OPG gene expression + reduces RANKL expression in osteoblasts → net reduction in osteoclast activity → bone preservation. Menopause estrogen loss → OPG falls + RANKL rises → osteoclast dominance → bone resorption exceeds formation → trabecular bone loss.",
        "cortisol_effect": "Chronic cortisol → reduces OPG, increases RANKL → osteoclast dominance. Also directly reduces intestinal calcium absorption, increases renal calcium excretion. Dual mechanism of corticosteroid-induced osteoporosis. Ref: HOR_CORTISOL_001"
      },
      "osteocalcin_endocrine_function": {
        "production": "Osteoblasts produce osteocalcin (OC) — a small protein requiring gamma-carboxylation of three glutamate residues by Vitamin K2-dependent enzyme. Uncarboxylated osteocalcin (ucOC) has the endocrine function.",
        "insulin_sensitivity": "Undercarboxylated osteocalcin → binds GPRC6A receptor on pancreatic beta cells → increases insulin secretion and expression. Also acts on skeletal muscle → increases GLUT4 expression → improves glucose uptake. Osteocalcin is therefore a bone-derived insulin sensitiser.",
        "testosterone_connection": "Osteocalcin binds GPRC6A on Leydig cells in testes → stimulates testosterone production. Exercise-induced osteocalcin elevation may partially explain exercise-driven testosterone increase.",
        "Vitamin_K2_requirement": "Gamma-carboxylation of osteocalcin requires Vitamin K2 (menaquinone — produced by gut bacteria and found in fermented foods, dairy). K2 deficiency → undercarboxylated osteocalcin — paradoxically, ucOC has MORE endocrine activity (insulin sensitising). But fully uncarboxylated also means reduced calcium binding → less effective at mineralisation. Balance is complex."
      },
      "Wolff_Law_mechanism": {
        "mechanosensation": "Osteocytes detect mechanical strain via deformation of their lacuno-canalicular network → calcium influx via piezo channels → prostaglandin E2 secretion → IGF-1 release → osteoblast activation → bone formation at loaded sites",
        "immobilisation_loss": "Without mechanical loading, osteocytes produce sclerostin → blocks Wnt signalling → inhibits osteoblasts → uncoupling → bone loss. This is why bed rest causes rapid bone loss — 1 to 2 percent per month in trabecular bone."
      }
    },
    "cross_system_connections": {
      "to_metabolic_system": "Osteocalcin → insulin sensitiser → reduces BLD_INSULIN_RESISTANCE_001. Exercise-stimulated osteocalcin improvement.",
      "to_hormonal_system": "HOR_ESTROGEN_001 protects bone via OPG upregulation. HOR_CORTISOL_001 devastates bone via dual mechanism. HOR_TESTOSTERONE_001 also protects bone mass (aromatised to estrogen in bone).",
      "to_energy_system": "Bone marrow red cells produced here → haemoglobin → oxygen delivery to all tissues including BIO_HAIRBULB_001",
      "to_digestive_system": "BIO_MICROBIOME_001 produces Vitamin K2 — required for osteocalcin carboxylation"
    },
