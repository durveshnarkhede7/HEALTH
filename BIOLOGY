  "BIO_GUTLINING_001": {
    "id": "BIO_GUTLINING_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Intestinal Epithelial Lining",
    "parent_system": "SYS_DIGESTIVE_001",
    "definition": "A single-cell-thick layer of intestinal epithelial cells (IECs) lining the entire small and large intestine — when fully unfolded, presenting approximately 400 square meters of absorptive surface area. The most rapidly renewing epithelium in the body, replacing itself completely every 3 to 5 days. The sole physical barrier separating the 38 trillion microorganisms of the gut lumen from the bloodstream.",
    "function": "Selective absorption of nutrients (amino acids, monosaccharides, fatty acids, vitamins, minerals) while excluding pathogens, microbial toxins, and undigested macromolecules. Houses GALT (gut-associated lymphoid tissue) — the largest immune organ in the body. Secretes mucus, digestive enzymes (brush border enzymes), and hormones (GLP-1, GIP, CCK, PYY). Communicates with the enteric nervous system (ENS) and with the brain via the vagal nerve.",
    "cellular_architecture": {
      "enterocytes": "Absorptive cells — 80 percent of epithelium. Tall columnar cells with apical microvilli (brush border). Express nutrient transporters. Polarised: apical membrane faces lumen, basolateral membrane faces capillaries.",
      "goblet_cells": "15 percent of epithelium. Produce mucin glycoproteins. Density increases distal to proximal — colon has highest goblet cell density.",
      "enteroendocrine_cells": "1 percent but critical. Produce GLP-1 (L cells), GIP (K cells), CCK, PYY — hormones regulating satiety, insulin release, gastric emptying.",
      "Paneth_cells": "Only in small intestinal crypts. Produce defensins, lysozyme, and REG3 — antimicrobial proteins defending crypt stem cells.",
      "tuft_cells": "Rare chemosensory cells detecting luminal parasites and microbiome composition. Produce IL-25 signalling to immune cells.",
      "M_cells": "Over Peyer's patches — transcytose antigens from lumen to GALT immune cells for sampling."
    },
    "crypt_villus_axis": {
      "crypts_of_Lieberkuhn": "Invaginations between villi. Contain intestinal stem cells (Lgr5+ cells) which self-renew and generate all IEC lineages. Transit-amplifying progenitors intermediate between stem cell and mature cell. Paneth cells provide niche signals.",
      "villi": "Finger-like projections extending into lumen — 0.5 to 1.6 mm tall in small intestine. Covered by enterocytes and goblet cells. Extend surface area 30-fold.",
      "microvilli": "Dense covering on enterocyte apical surface — brush border. Extend surface area further 600-fold. Contain disaccharidases, peptidases, and nutrient transporters.",
      "renewal_rate": "Complete epithelial renewal every 3 to 5 days — among the fastest turnover rates in the body. This is why IECs are highly sensitive to any reduction in energy or substrate supply."
    },
    "molecular_mechanism": {
      "tight_junction_complex": {
        "components": "Claudins (claudin-1, 2, 3, 4, 5 — tissue specific expression), occludin, junctional adhesion molecules (JAMs), and ZO scaffold proteins (ZO-1, ZO-2, ZO-3)",
        "zinc_requirement": "ZO-1 and claudin-1 expression requires zinc. Zinc also required for occludin phosphorylation maintaining junction integrity. Zinc deficiency → looser tight junctions → increased permeability. Ref: NUT_ZINC_001",
        "butyrate_maintenance": "Butyrate (from BIO_MICROBIOME_001) → HDAC inhibition → upregulates claudin-3 and occludin expression → tighter junctions",
        "disruption_factors": "NSAIDs (inhibit COX-2 prostaglandins needed for mucosal repair). Alcohol (acetaldehyde disrupts claudin-1). Stress cortisol (downregulates tight junction proteins). Gluten (gliadin activates zonulin in susceptible individuals → tight junction opening)."
      },
      "leaky_gut_inflammatory_cascade": {
        "step_1": "Tight junction integrity compromised → paracellular permeability increases → bacterial lipopolysaccharide (LPS) from gram-negative bacteria translocates into portal circulation",
        "step_2": "LPS binds TLR-4 (with MD-2 coreceptor) on monocytes, macrophages, and Kupffer cells in liver → MyD88 adaptor → NF-kB activation → TNF-alpha, IL-6, IL-1beta secretion",
        "step_3": "Systemic low-grade endotoxaemia — detectable LPS in plasma at pg/mL concentrations — produces chronic low-grade inflammatory state (see INF_CHRONIC_001)",
        "step_4": "Systemic inflammation → increases cortisol → reduces thyroid T3 conversion → impairs insulin signalling → promotes hair loss, fatigue, acne — multi-system cascade from single gut event"
      },
      "nutrient_transporters": {
        "iron": "DMT-1 (divalent metal transporter 1) on enterocyte apical surface imports Fe2+. Ferroportin on basolateral surface exports to bloodstream. Hephaestin (copper-dependent ferroxidase) on basolateral surface oxidises Fe2+ to Fe3+ for transferrin binding. Ref: ABS_IRON_001, NUT_COPPER_001",
        "B12": "Intrinsic factor (IF) secreted by gastric parietal cells binds dietary B12 → IF-B12 complex binds cubilin receptor on ileal enterocytes → endocytosed → B12 released into portal blood. PPIs reduce gastric acid → reduced pepsin release of food-bound B12 → impaired absorption. Ref: ABS_B12_001, MEDS_PPIS_001",
        "zinc": "Zip4 transporter imports Zn2+ on apical surface. ZnT1 exports on basolateral surface. Phytate from grains and legumes chelates zinc in lumen → insoluble complex → reduced Zip4 access. Ref: ABS_ZINC_001",
        "vitamin_D": "Passive diffusion at physiological doses. At pharmacological doses, carrier-mediated. Fat-soluble — requires dietary fat in same meal for micellar incorporation and chylomicron transport to lymphatics. Ref: ABS_VITD_001"
      },
      "mucus_barrier": {
        "two_layers": "Inner mucus layer (firmly adherent to epithelium, sterile, dense — bacteria cannot penetrate) and outer mucus layer (colonised by commensal bacteria, looser)",
        "mucin_production": "Goblet cells produce MUC2 mucin → disulphide crosslinked polymers → gel network. Goblet cell activity stimulated by butyrate. Reduced by chronic stress cortisol.",
        "barrier_function": "Mucus layer prevents direct bacterial contact with epithelium. Antimicrobial proteins (defensins, REG3) concentrated in mucus provide additional chemical barrier."
      },
      "glutamine_critical_dependency": {
        "role": "L-glutamine is the primary metabolic fuel for enterocytes — used preferentially over glucose. Provides carbon skeleton for nucleotide synthesis (rapidly dividing IECs), nitrogen for amino acid synthesis, and antioxidant support via glutathione precursor activity.",
        "stress_depletion": "Physiological stress (illness, surgery, extreme exercise) → muscle glutamine release → increased plasma demand → reduced gut supply → enterocyte energy deficit → tight junction loosening → leaky gut",
        "clinical_use": "Oral glutamine supplementation reduces intestinal permeability markers in clinical trials — particularly relevant in post-illness hair loss recovery where gut integrity is compromised"
      },
      "enteric_nervous_system": {
        "definition": "The ENS is a network of 200 to 600 million neurons embedded in the gut wall (more than the spinal cord) — operates semi-independently from the central nervous system. Called the 'second brain'.",
        "microbiome_communication": "Gut bacteria → SCFAs → activate enteric neurons. Serotonin from EC cells → 5-HT3 receptors on enteric neurons → peristalsis coordination.",
        "stress_effect": "Psychological stress → sympathetic nervous system activation → reduced mesenteric blood flow → reduced gut motility → altered microbiome composition → increased permeability — complete pathway from mental stress to gut dysfunction"
      }
    },
    "cross_system_connections": {
      "to_hair_system": "All nutrients for hair (iron, zinc, B12, protein) absorbed here. Any gut lining compromise → nutrient deficiency → hair loss.",
      "to_energy_system": "Nutrient absorption by gut lining delivers substrates to BIO_MITOCHONDRIA_001",
      "to_immune_system": "GALT in gut lining houses 70-80 percent of immune cells",
      "to_microbiome": "Tight junction integrity maintained by butyrate from BIO_MICROBIOME_001 — bidirectional dependence"
    },
    "damage_pathways": {
      "nutritional": ["NUT_ZINC_001"],
      "stress": "STR_CHRONIC_001",
      "medications": ["MEDS_PPIS_001", "MEDS_ANTIBIOTICS_001"],
      "lifestyle_chemical": "Alcohol (acetaldehyde), NSAIDs (COX inhibition reduces prostaglandin mucosal protection)",
      "inflammatory": ["INF_CHRONIC_001"],
      "dysbiosis": "GUT_DYSBIOSIS_001",
      "downstream_consequences": ["GUT_LEAKYGUT_001", "GUT_MALABSORPTION_001"]
    },
    "recovery_pathways": {
      "nutritional": ["NUT_ZINC_001"],
      "glutamine": "L-glutamine supports enterocyte energy and tight junction repair",
      "microbiome_support": "BIO_MICROBIOME_001 butyrate production maintains tight junctions",
      "dietary": "Bone broth (glycine, glutamine, collagen peptides). Fermented foods. Prebiotic fibre.",
      "intervention_ref": "INT_GUT_001"
    },
    "tags": ["intestinal lining", "enterocytes", "tight junctions", "claudin", "ZO-1", "leaky gut", "LPS", "TLR-4", "DMT-1", "B12 absorption", "zinc absorption", "Lgr5 stem cells", "villi", "microvilli", "mucus", "goblet cells", "glutamine", "enteric nervous system", "GALT"]
  },
  "BIO_PANCREAS_001": {
    "id": "BIO_PANCREAS_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Pancreas",
    "parent_system": "SYS_METABOLIC_001",
    "definition": "A retroperitoneal gland weighing 60 to 100 grams with dual exocrine (acinar cells) and endocrine (islets of Langerhans) populations. The endocrine pancreas — representing only 1 to 2 percent of total pancreatic mass — is the exclusive site of insulin, glucagon, and somatostatin production and the master regulator of blood glucose homeostasis.",
    "function": "Exocrine: secretes 1.5 to 2 litres of enzyme-rich bicarbonate fluid daily into the duodenum via the pancreatic duct — lipase (fat digestion), amylase (starch), elastase and trypsin/chymotrypsin (protein). Endocrine: islets of Langerhans secrete insulin (beta cells — 65-80 percent of islet), glucagon (alpha cells — 15-20 percent), somatostatin (delta cells — 5 percent), and pancreatic polypeptide (PP cells) directly into portal vein.",
    "islet_cellular_detail": {
      "beta_cells": {
        "glucose_sensing": "Express GLUT2 (high Km — non-saturable at physiological glucose) and glucokinase (rate-limiting glucose-sensing enzyme). This combination makes beta cells exquisite glucose concentration sensors.",
        "secretion_mechanism": "Glucose → glycolysis → ATP:ADP ratio rises → KATP channels close → membrane depolarisation → voltage-gated Ca2+ channels open → Ca2+ influx → insulin granule fusion with plasma membrane → insulin exocytosis",
        "zinc_storage": "Insulin is stored in crystalline form as a Zn2+-insulin hexamer in secretory granules. Six insulin molecules coordinate 2 zinc ions to form stable hexamer. Zinc is required for insulin crystallisation, storage, and pH-triggered monomerisation during exocytosis. Zinc deficiency impairs insulin storage capacity and secretion efficiency. Ref: NUT_ZINC_001",
        "first_phase_second_phase": "First phase: pre-formed granule exocytosis within 1 to 3 minutes of glucose stimulus. Second phase: de novo insulin synthesis and newly granulated exocytosis over next 60 to 90 minutes. Type 2 diabetes — first phase blunted early, both phases reduced later."
      },
      "alpha_cells": {
        "glucagon": "Secreted when glucose falls. Stimulates hepatic glycogenolysis (glycogen breakdown → glucose) and gluconeogenesis (amino acid → glucose). Prevents hypoglycaemia between meals.",
        "suppression": "Normally suppressed by adjacent beta cell insulin and somatostatin. In T2DM → inappropriately elevated glucagon → contributes to fasting hyperglycaemia."
      },
      "delta_cells": {
        "somatostatin": "Paracrine inhibitor of both insulin and glucagon secretion. Fine-tunes postprandial islet hormone balance."
      }
    },
    "molecular_mechanism": {
      "insulin_resistance_progression": {
        "stage_1_compensated": "Tissue insulin resistance → reduced GLUT4 translocation → hyperglycaemia → beta cells compensate by increasing insulin secretion → hyperinsulinaemia maintains normoglycaemia. Duration: years to decades.",
        "stage_2_impaired_fasting": "Beta cell mass starts declining (glucotoxicity, lipotoxicity, ER stress, mitochondrial ROS) → insufficient insulin to maintain fasting normoglycaemia → impaired fasting glucose (IFG: 100-125 mg/dL)",
        "stage_3_T2DM": "Beta cell function below 50 percent of original capacity → frank hyperglycaemia regardless of insulin dose → type 2 diabetes diagnosis"
      },
      "glucotoxicity": {
        "mechanism": "Persistently elevated blood glucose → increased glucose flux through mitochondrial ETC in beta cells → superoxide overproduction → activation of stress kinases (JNK, p38) → pdx1 transcription factor downregulation → reduced insulin gene transcription → beta cell dedifferentiation and apoptosis",
        "ROS_specificity": "Beta cells express exceptionally low levels of antioxidant enzymes (catalase, GPx) compared to other tissues — making them uniquely susceptible to oxidative stress from excess glucose"
      },
      "lipotoxicity": {
        "mechanism": "Chronically elevated fatty acids (from insulin resistance-driven lipolysis) → ceramide synthesis in beta cells → protein phosphatase 2A activation → Akt dephosphorylation → apoptosis. Saturated fatty acids (palmitate, stearate) more lipotoxic than unsaturated. Ref: NUT_OMEGA3_001 for protective mechanism"
      },
      "zinc_insulin_connection": {
        "synthesis": "Zinc incorporated into insulin hexamers during proinsulin conversion to insulin in the trans-Golgi",
        "crystal_pH": "At pH 7.4 (blood) → hexamers dissociate to monomers (active form). Within granule pH 5-6 → hexamer stable. pH change during exocytosis triggers monomerisation.",
        "deficiency_consequence": "Zinc deficiency → disrupted hexamer formation → impaired insulin storage and granule maturity → reduced first-phase secretion. Zinc also required for insulin-degrading enzyme (IDE) activity — deficiency alters insulin clearance.",
        "ref": "NUT_ZINC_001"
      },
      "incretin_pathway": {
        "GLP1": "Glucagon-like peptide-1 secreted by L cells in ileum and colon in response to nutrients → binds GLP-1R on beta cells → Gs → cAMP → PKA → potentiates glucose-stimulated insulin secretion. Also inhibits glucagon, slows gastric emptying, promotes satiety.",
        "GIP": "Glucose-dependent insulinotropic polypeptide from K cells in duodenum. Potentiates insulin secretion. Also promotes adipose tissue triglyceride storage — links diet composition to fat deposition.",
        "GLP1_microbiome": "Gut microbiome SCFAs (propionate, butyrate) stimulate L cell GLP-1 secretion via GPR41/43 receptors. Dysbiosis → reduced SCFA → reduced GLP-1 → impaired insulin response → metabolic dysfunction pathway from gut to pancreas."
      }
    },
    "cross_system_connections": {
      "to_hair_system": "Hyperinsulinaemia → androgen excess (via reduced SHBG and ovarian androgen) → BIO_DERMALPAPILLA_001 miniaturisation and BIO_SEBGLAND_001 sebum overproduction",
      "to_digestive_system": "Exocrine function: all nutrient digestion depends on pancreatic enzyme secretion. Impaired exocrine → malabsorption → all nutrient deficiencies including for hair",
      "to_hormonal_system": "Insulin regulates SHBG (sex hormone binding globulin) production in liver — hyperinsulinaemia reduces SHBG → increases free testosterone → increased DHT → hair loss and acne",
      "to_microbiome": "GLP-1 is stimulated by gut microbiome SCFAs — gut health directly affects pancreatic hormone regulation"
    },
    "hormones_produced": ["HOR_INSULIN_001"],
    "damage_pathways": {
      "dietary": "High glycaemic diet, chronic caloric excess, trans fats",
      "blood_sugar": ["BLD_INSULIN_RESISTANCE_001", "BLD_PREDIABETES_001"],
      "oxidative": ["OXI_FREE_RADICAL_001"],
      "inflammatory": ["INF_CHRONIC_001"]
    },
    "lab_markers": ["LAB_FASTING_INSULIN_001", "LAB_HBA1C_001", "LAB_FASTING_GLUCOSE_001", "LAB_HOMA_IR_001"],
    "tags": ["pancreas", "beta cells", "insulin", "glucagon", "GLUT2", "glucokinase", "zinc", "KATP channels", "GLP-1", "incretin", "glucotoxicity", "lipotoxicity", "islets of Langerhans", "SHBG", "insulin resistance"]
  },
  "BIO_PITUITARY_001": {
    "id": "BIO_PITUITARY_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Pituitary Gland",
    "parent_system": "SYS_HORMONAL_001",
    "definition": "A bilobed neuroendocrine gland weighing approximately 0.5 to 0.6 grams, housed in the sella turcica of the sphenoid bone, connected to the hypothalamus via the pituitary stalk (infundibulum). The most functionally diverse endocrine gland — its tropic hormones regulate thyroid, adrenal, gonads, growth, and lactation, making it the master orchestrator of the endocrine system.",
    "function": "Anterior pituitary (adenohypophysis — glandular tissue): produces TSH (thyroid), ACTH (adrenal), LH and FSH (gonads), GH (growth and metabolism), and prolactin (lactation and reproductive function). Posterior pituitary (neurohypophysis — neural tissue): stores and releases ADH (water balance) and oxytocin (social bonding, labour, lactation) — these are actually produced in the hypothalamus and transported down.",
    "cellular_populations_anterior": {
      "thyrotrophs": {
        "hormone": "TSH (thyroid-stimulating hormone)",
        "stimulated_by": "Hypothalamic TRH",
        "inhibited_by": "T3 (via D2 conversion of T4 in pituitary itself) — D2-generated intracellular T3 is the primary suppressor",
        "hair_relevance": "TSH controls thyroid T4 output → T3 generated by deiodinases → T3 at BIO_MATRIX_001 and BIO_FOLLICLE_001"
      },
      "corticotrophs": {
        "hormone": "ACTH (adrenocorticotropic hormone)",
        "stimulated_by": "Hypothalamic CRH and vasopressin (synergistic)",
        "inhibited_by": "Cortisol (glucocorticoid receptor in corticotrophs — negative feedback)",
        "hair_relevance": "ACTH → BIO_ADRENAL_001 cortisol → telogen effluvium pathway"
      },
      "gonadotrophs": {
        "hormone": "LH and FSH",
        "stimulated_by": "Hypothalamic GnRH — PULSATILE secretion is required. Continuous GnRH paradoxically suppresses LH/FSH (basis of GnRH agonist therapy).",
        "LH_FSH_ratio": "Normal LH:FSH ratio 1:1. In PCOS — elevated LH pulse frequency → elevated LH:FSH ratio (often greater than 2:1) → excessive ovarian androgen secretion",
        "hair_relevance": "LH:FSH ratio diagnostic for PCOS — ref LAB_LH_FSH_RATIO_001. Ovarian androgen → DHT → hair loss. Ref: MED_PCOS_001"
      },
      "somatotrophs": {
        "hormone": "GH (growth hormone)",
