  "BIO_ADRENAL_001": {
    "id": "BIO_ADRENAL_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Adrenal Glands",
    "parent_system": "SYS_HORMONAL_001",
    "definition": "Paired pyramidal endocrine glands weighing 4 to 5 grams each, situated atop the kidneys. Each gland is functionally two organs in one \u2014 the outer cortex (mesodermal origin, produces steroid hormones) and the inner medulla (neural crest origin, produces catecholamines). The cortex is divided into three zones with completely distinct cell populations and hormone products.",
    "function": "Adrenal cortex: cortisol (glucose regulation, immune modulation, stress response), aldosterone (sodium and blood pressure control), DHEA and androstenedione (adrenal androgens \u2014 converted peripherally to testosterone and DHT). Adrenal medulla: adrenaline and noradrenaline (acute sympathetic stress response \u2014 fight or flight).",
    "anatomical_zones": {
      "zona_glomerulosa": {
        "location": "Outermost cortex. 15 percent of cortical volume.",
        "hormone": "Aldosterone",
        "regulator": "Angiotensin II and serum potassium (NOT ACTH primarily)",
        "function": "Promotes renal sodium retention \u2192 water retention \u2192 blood pressure elevation. The final effector of the renin-angiotensin-aldosterone system (RAAS)."
      },
      "zona_fasciculata": {
        "location": "Middle cortex. 75 percent of cortical volume. Lipid-laden cells \u2014 visible yellow grossly.",
        "hormone": "Cortisol",
        "regulator": "ACTH from pituitary \u2014 pulsatile, with circadian peak at 6 to 8 AM",
        "function": "Gluconeogenesis. Immune suppression. Anti-inflammatory (acute). Mobilises amino acids and fatty acids for energy. Regulates water balance with aldosterone. Essential for survival."
      },
      "zona_reticularis": {
        "location": "Innermost cortex. 10 percent of cortical volume.",
        "hormone": "DHEA, DHEAS, androstenedione",
        "regulator": "ACTH and insulin-like growth factors",
        "function": "Primary source of DHEA in adults. Peripherally converted to testosterone and DHT \u2014 particularly significant in women where this accounts for majority of circulating androgens before menopause.",
        "chronic_stress_effect": "Chronic ACTH elevation from HPA axis hyperactivation \u2192 zona reticularis stimulation \u2192 elevated DHEA \u2192 elevated peripheral androgen conversion \u2192 acne, hair loss, and sebum excess in women with chronic stress"
      },
      "adrenal_medulla": {
        "cells": "Chromaffin cells \u2014 modified sympathetic neurons retaining catecholamine-producing capacity",
        "hormones": "Adrenaline (80 percent), noradrenaline (20 percent)",
        "regulator": "Direct sympathetic neural stimulation \u2014 responds within seconds to acute threat",
        "effects": "Increased heart rate and contractility, blood pressure rise, glucose mobilisation from liver, bronchodilation, fat mobilisation, blood flow redistribution to muscles and brain"
      }
    },
    "cellular_mechanism": "The HPA (hypothalamic-pituitary-adrenal) axis controls cortisol: psychological or physiological stress \u2192 paraventricular nucleus of hypothalamus \u2192 CRH release \u2192 anterior pituitary corticotrophs \u2192 ACTH release \u2192 zona fasciculata \u2192 cortisol synthesis and release. Cortisol provides negative feedback to both hypothalamus and pituitary \u2014 the normal off-switch. In chronic stress, feedback resistance develops \u2192 persistently elevated cortisol.",
    "molecular_mechanism": {
      "cortisol_synthesis": {
        "substrate": "Cholesterol \u2014 taken from LDL particles or synthesised de novo",
        "StAR_protein": "Steroidogenic Acute Regulatory protein transports cholesterol from outer to inner mitochondrial membrane \u2014 rate-limiting step in steroidogenesis. ACTH activation \u2192 StAR phosphorylation via PKA",
        "cytochrome_P450_cascade": "Cholesterol \u2192 pregnenolone (CYP11A1 in mitochondria) \u2192 progesterone (3beta-HSD in ER) \u2192 17-OH progesterone (CYP17A1) \u2192 cortisol (CYP21A2 then CYP11B1)",
        "vitamin_C_adrenal": "Adrenal cortex contains the highest Vitamin C concentration of any tissue \u2014 30 to 50x plasma levels. Vitamin C is required for the multiple cytochrome P450 reactions in cortisol synthesis and for antioxidant protection against ROS generated during steroidogenesis. Adrenal Vitamin C is depleted by acute ACTH stimulation. Ref: NUT_VITC_001"
      },
      "cortisol_hair_follicle_effect": {
        "mechanism": "Glucocorticoid receptor (GR) is expressed in hair follicle \u2014 both in dermal papilla and in outer root sheath. Cortisol binds GR \u2192 nuclear translocation \u2192 transactivates DKK-1 and activin A genes \u2192 inhibits Wnt/beta-catenin pathway \u2192 premature catagen induction. Cortisol also upregulates local follicular CRH production \u2014 creating an intrafollicular stress amplification loop.",
        "telogen_trigger_threshold": "Acute stress cortisol spike \u2192 follicles in late anagen most susceptible \u2192 synchronised catagen entry \u2192 2 to 3 month later mass shedding (classic presentation of telogen effluvium)"
      },
      "cortisol_immune_effects": {
        "anti_inflammatory_acute": "Acute cortisol \u2192 phospholipase A2 inhibition (via annexin-1) \u2192 reduced prostaglandin synthesis \u2192 anti-inflammatory. Lymphocyte apoptosis induction. NK cell function suppression.",
        "chronic_paradox": "Chronic cortisol \u2192 glucocorticoid receptor downregulation on immune cells \u2192 reduced cortisol sensitivity \u2192 immune dysregulation \u2192 paradoxically increased systemic inflammation \u2192 chronic low-grade inflammatory state (INF_CHRONIC_001)",
        "autoimmune_risk": "Chronic HPA dysregulation \u2192 Treg dysfunction \u2192 increased autoimmune susceptibility \u2192 thyroid autoimmunity risk increases"
      },
      "DHEA_androgen_conversion": {
        "peripheral_conversion": "DHEA \u2192 androstenedione (via 3beta-HSD) \u2192 testosterone (via 17beta-HSD) \u2192 DHT (via 5-alpha reductase in target tissues including skin, scalp, sebaceous gland). This conversion occurs in skin, adipose, liver, and muscle \u2014 not requiring adrenal or ovarian output.",
        "women_significance": "In women, adrenal DHEA accounts for 50 percent of androgens pre-menopause. Elevated DHEAS from stress or adrenal hyperfunction \u2192 elevated skin androgens \u2192 acne and hair loss without elevated total testosterone.",
        "ref": "HOR_DHEA_001"
      }
    },
    "HPA_axis_dysregulation": {
      "acute_stress": "CRH \u2192 ACTH \u2192 cortisol \u2192 negative feedback. Normal. Adaptive. Protective.",
      "chronic_stress": "Persistent CRH secretion \u2192 pituitary ACTH hyperresponsiveness \u2192 sustained cortisol elevation \u2192 GR downregulation \u2192 loss of negative feedback sensitivity \u2192 HPA axis remains activated \u2192 cortisol chronically elevated or dysrhythmic (loss of circadian pattern)",
      "burnout_phase": "After years of chronic HPA activation \u2192 adrenal steroidogenic capacity reduces \u2192 flat, low-amplitude cortisol curve \u2192 adrenal 'fatigue' (though 'HPA axis dysregulation' is the clinically preferred term)"
    },
    "cross_system_connections": {
      "to_hair_system": "Cortisol causes telogen effluvium via BIO_FOLLICLE_001 and BIO_DERMALPAPILLA_001. DHEA drives androgen excess via BIO_SEBGLAND_001.",
      "to_thyroid_system": "Cortisol \u2192 D3 upregulation + D2 downregulation \u2192 reduced FT3. Chronic stress suppresses thyroid via this mechanism.",
      "to_metabolic_system": "Cortisol promotes gluconeogenesis \u2192 raises blood glucose \u2192 drives insulin resistance (BLD_INSULIN_RESISTANCE_001)",
      "to_immune_system": "Acute cortisol is anti-inflammatory. Chronic cortisol causes immune dysregulation."
