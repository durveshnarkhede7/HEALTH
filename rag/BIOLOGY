  "BIO_ETC_001": {
    "id": "BIO_ETC_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Electron Transport Chain",
    "parent_system": "SYS_ENERGY_001",
    "parent_structure": "BIO_MITOCHONDRIA_001",
    "definition": "A series of five protein complexes (Complex I through V) embedded in the inner mitochondrial membrane that transfer electrons from NADH and FADH2 through a chain of redox carriers to molecular oxygen, generating a transmembrane proton gradient (chemiosmotic potential) that drives ATP synthesis.",
    "function": "Harvests the energy stored in NADH and FADH2 (from Krebs cycle) and converts it into an electrochemical proton gradient across the inner mitochondrial membrane. This gradient drives ATP synthase (Complex V) to phosphorylate ADP to ATP \u2014 the universal energy currency of the cell. Final electron acceptor is O2 \u2192 reduced to H2O.",
    "complexes_detailed": {
      "complex_I": {
        "name": "NADH:ubiquinone oxidoreductase",
        "function": "Accepts 2 electrons from NADH \u2192 transfers to ubiquinone (CoQ10) \u2192 pumps 4 protons across inner membrane",
        "structure": "L-shaped. 45 subunits. Contains 8 iron-sulphur (Fe-S) clusters and 1 FMN cofactor.",
        "iron_dependency": "Fe-S clusters are the electron relay chain within Complex I. Iron deficiency \u2192 incomplete Fe-S cluster assembly \u2192 reduced Complex I activity \u2192 reduced NADH oxidation rate \u2192 ATP deficit + increased electron leak \u2192 increased ROS"
      },
      "complex_II": {
        "name": "Succinate dehydrogenase",
        "function": "Connects Krebs cycle to ETC \u2014 oxidises succinate to fumarate \u2192 FADH2 \u2192 CoQ10. Does NOT pump protons.",
        "structure": "4 subunits. Contains 3 Fe-S clusters, 1 FAD cofactor, 1 haem b.",
        "iron_dependency": "Fe-S clusters required for electron transfer. Haem b is structural. Mutations in SDHB/C/D cause paragangliomas \u2014 demonstrating biological importance."
      },
      "complex_III": {
        "name": "Cytochrome bc1 complex",
        "function": "Transfers electrons from CoQ10 to cytochrome c \u2192 pumps 4 protons across inner membrane via Q-cycle mechanism",
        "structure": "11 subunits. Contains 2 haem b groups, 1 haem c1, 1 Rieske Fe-S cluster.",
        "iron_dependency": "Haem groups and Rieske Fe-S cluster all contain iron. Iron deficiency \u2192 impaired Complex III \u2192 bottleneck in electron flow \u2192 backup \u2192 increased superoxide generation at Complex I/III"
      },
      "complex_IV": {
        "name": "Cytochrome c oxidase",
        "function": "Terminal electron acceptor \u2014 reduces O2 to H2O. Pumps 2 protons per 2 electrons transferred.",
        "structure": "13 subunits in humans. Contains 3 copper centres (CuA, CuB, CuZ), 2 haem groups (haem a, haem a3), and 1 Mg2+ and 1 Zn2+ structural ion.",
        "copper_dependency": "CuA (in cytochrome c binding site) and CuB (in binuclear centre with haem a3 \u2014 the actual O2 reduction site) are catalytically essential. Copper deficiency \u2192 impaired Complex IV \u2192 reduced oxygen utilisation \u2192 cellular hypoxia despite normal O2 supply. Ref: NUT_COPPER_001"
      },
      "complex_V": {
        "name": "ATP synthase (F0F1-ATPase)",
        "function": "Uses proton gradient to phosphorylate ADP \u2192 ATP. F0 subunit in membrane rotates driven by proton flow. F1 subunit in matrix catalyses phosphorylation.",
        "structure": "F0 ring (10 c-subunits) + F1 headpiece (alpha3beta3gammadeltaepsilon). Rotary motor \u2014 among the smallest motors in nature.",
        "magnesium_requirement": "Mg2+ is required at the catalytic beta subunit for the phosphoryl transfer reaction. Without Mg2+, ATP synthesis rate drops significantly. Ref: NUT_MAGNESIUM_001"
      }
    },
    "proton_gradient_physiology": {
      "electrochemical_potential": "Approximately 180 mV across inner mitochondrial membrane \u2014 maintained by Complexes I, III, IV pumping protons to intermembrane space",
      "uncoupling": "Brown adipose tissue mitochondria express UCP1 (uncoupling protein) \u2014 allows protons back into matrix without passing through ATP synthase \u2192 proton gradient dissipated as heat \u2192 thermogenesis. Thyroid hormone upregulates UCP expression \u2014 mechanism of thyroid-controlled thermogenesis."
    },
    "ROS_generation_sites": {
      "complex_I_III": "Primary superoxide generation sites \u2014 electron leak at FMN site (Complex I) and ubisemiquinone site (Complex III)",
      "consequences": "O2- \u2192 SOD converts to H2O2 \u2192 catalase/GPx converts to H2O (normal). Overwhelmed \u2192 lipid peroxidation, protein carbonylation, mtDNA mutation",
      "iron_deficiency_amplification": "Iron deficiency \u2192 incomplete Fe-S clusters \u2192 electrons back up at Complex I/III \u2192 increased electron leak \u2192 increased ROS despite reduced total electron throughput \u2014 a paradox that worsens the oxidative environment"
    },
