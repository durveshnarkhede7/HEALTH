  "LFS_PUBERTY_001": {
    "id": "LFS_PUBERTY_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Puberty (The Anabolic Surge)",
    "biological_shift": "Massive exponential increase in Growth Hormone (GH), IGF-1, Sex Hormones (Testosterone, Estrogen), and Insulin.",
    "metabolic_vulnerabilities": [
      "Physiological Insulin Resistance: The body becomes naturally insulin resistant to partition circulating glucose away from fat cells and towards rapidly growing bone and muscle tissue.",
      "Adipocyte Hyperplasia: If an Indian teenager consumes a highly processed, high-sugar diet during this specific window, the insulin resistance turns pathological. The body creates millions of NEW fat cells (hyperplasia) rather than just filling existing ones. This permanently locks in a higher 'Fat Cell Count' for the rest of their life, pre-disposing them to severe adult obesity."
    ],
    "symptom_manifestation": [
      "SYM_ACNE_001 (Driven by the GH/IGF-1/Insulin surge hitting the sebaceous glands)",
      "SYM_WEIGHTGAIN_001 (If diet is poor)"
    ],
    "related_nodes": ["HOR_IGF1_001", "BSG_INSULIN_RESISTANCE_001", "BIO_SEBACEOUSGLAND_001"]
  },
  "LFS_REPRODUCTIVE_FEMALE_001": {
    "id": "LFS_REPRODUCTIVE_FEMALE_001",
    "node_type": "life_stage",
    "version": "1.0",
    "name": "Female Reproductive Years (The 28-Day Cycle)",
    "biological_shift": "A continuous 28-day wave of fluctuating Estrogen and Progesterone, entirely altering metabolism week by week.",
    "metabolic_vulnerabilities": [
      "Follicular Phase (Days 1-14): Estrogen dominant. The female body is highly insulin sensitive and preferentially burns carbohydrates for fuel. Cortisol is low. This is the optimal time for high-intensity exercise (HIIT) and higher carbohydrate intake.",
      "Luteal Phase (Days 15-28): Progesterone dominant. The body temperature rises. The female body becomes naturally insulin resistant to prepare the uterine lining for potential pregnancy. It shifts to preferentially burning fat for fuel. Carbohydrate tolerance plummets, causing extreme sugar cravings if the diet isn't adjusted. Serotonin drops, causing PMS mood swings."
    ],
    "symptom_manifestation": [
      "SYM_FATIGUE_001 (In luteal phase if eating too many carbs)",
      "SYM_ACNE_001 (Premenstrual acne due to progesterone/testosterone spikes when estrogen drops)"
    ],
    "related_nodes": ["HOR_ESTROGEN_001", "HOR_PROGESTERONE_001", "BSG_INSULIN_RESISTANCE_001"]
  },
