  "OXI_GLYCATION_001": {
    "id": "OXI_GLYCATION_001",
    "node_type": "oxidative_stress",
    "version": "1.0",
    "name": "Glycation & Advanced Glycation End-products (AGEs)",
    "definition": "A non-enzymatic reaction where excess blood glucose permanently binds to proteins (and lipids/DNA), forming irreversible cross-links called Advanced Glycation End-products (AGEs). AGEs are both a cause and a consequence of oxidative stress.",
    "mechanism": {
      "maillard_reaction": "Glucose reacts with amino groups on proteins (especially lysine and arginine residues) → Schiff base → Amadori product (e.g., HbA1c) → irreversible AGE crosslinks. This is the exact same 'browning' reaction as cooking food.",
      "RAGE_activation": "AGEs bind to the Receptor for AGEs (RAGE) on cell surfaces → triggers NF-kB → massive inflammatory cytokine release (TNF-alpha, IL-6) → further ROS generation. This creates a vicious glycation-inflammation-oxidative stress triangle.",
      "collagen_crosslinking": "Collagen has a 15-year half-life — it cannot easily be replaced. Once glycated, collagen becomes rigid, brittle, and dysfunctional. This is why diabetics age faster, have poor wound healing, and develop skin changes."
    },
    "tissue_targets": [
      "BIO_DERMIS_001 (Glycated collagen → wrinkles, loss of elasticity, 'sugar face')",
      "BIO_FOLLICLE_001 (Glycated dermal papilla basement membrane → impaired nutrient delivery to matrix)",
      "BIO_CARDIOVASCULAR_001 (Glycated arterial walls → atherosclerosis)",
      "BIO_NERVOUS_001 (Glycated myelin → peripheral neuropathy in diabetics)",
      "BIO_KIDNEY_001 (Glycated glomerular basement membrane → diabetic nephropathy)"
    ],
    "nutritional_connection": [
      "NUT_CARBS_001 (High blood sugar is the primary substrate for glycation)",
      "HOR_INSULIN_001 (Insulin resistance → chronically elevated blood sugar → accelerated glycation)",
      "NUT_B1_001 (Benfotiamine — a B1 derivative — blocks multiple glycation pathways)"
    ],
    "indian_context": "India is the diabetes capital of the world with 100+ million diabetics and 140+ million prediabetics. The high refined carbohydrate diet (white rice, maida, sugar in chai) combined with sedentary lifestyles means AGE formation is accelerated in a massive percentage of the population. Dietary AGEs from tandoori/grilled foods (high-heat cooking) add exogenous AGEs to the endogenous burden."
  },
