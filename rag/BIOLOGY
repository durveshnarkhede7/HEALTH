  "BIO_GUTLINING_001": {
    "id": "BIO_GUTLINING_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Intestinal Epithelial Lining",
    "parent_system": "SYS_DIGESTIVE_001",
    "definition": "A single-cell-thick layer of intestinal epithelial cells (IECs) lining the entire small and large intestine \u2014 when fully unfolded, presenting approximately 400 square meters of absorptive surface area. The most rapidly renewing epithelium in the body, replacing itself completely every 3 to 5 days. The sole physical barrier separating the 38 trillion microorganisms of the gut lumen from the bloodstream.",
    "function": "Selective absorption of nutrients (amino acids, monosaccharides, fatty acids, vitamins, minerals) while excluding pathogens, microbial toxins, and undigested macromolecules. Houses GALT (gut-associated lymphoid tissue) \u2014 the largest immune organ in the body. Secretes mucus, digestive enzymes (brush border enzymes), and hormones (GLP-1, GIP, CCK, PYY). Communicates with the enteric nervous system (ENS) and with the brain via the vagal nerve.",
    "cellular_architecture": {
      "enterocytes": "Absorptive cells \u2014 80 percent of epithelium. Tall columnar cells with apical microvilli (brush border). Express nutrient transporters. Polarised: apical membrane faces lumen, basolateral membrane faces capillaries.",
      "goblet_cells": "15 percent of epithelium. Produce mucin glycoproteins. Density increases distal to proximal \u2014 colon has highest goblet cell density.",
      "enteroendocrine_cells": "1 percent but critical. Produce GLP-1 (L cells), GIP (K cells), CCK, PYY \u2014 hormones regulating satiety, insulin release, gastric emptying.",
      "Paneth_cells": "Only in small intestinal crypts. Produce defensins, lysozyme, and REG3 \u2014 antimicrobial proteins defending crypt stem cells.",
      "tuft_cells": "Rare chemosensory cells detecting luminal parasites and microbiome composition. Produce IL-25 signalling to immune cells.",
      "M_cells": "Over Peyer's patches \u2014 transcytose antigens from lumen to GALT immune cells for sampling."
    },
    "crypt_villus_axis": {
      "crypts_of_Lieberkuhn": "Invaginations between villi. Contain intestinal stem cells (Lgr5+ cells) which self-renew and generate all IEC lineages. Transit-amplifying progenitors intermediate between stem cell and mature cell. Paneth cells provide niche signals.",
      "villi": "Finger-like projections extending into lumen \u2014 0.5 to 1.6 mm tall in small intestine. Covered by enterocytes and goblet cells. Extend surface area 30-fold.",
      "microvilli": "Dense covering on enterocyte apical surface \u2014 brush border. Extend surface area further 600-fold. Contain disaccharidases, peptidases, and nutrient transporters.",
      "renewal_rate": "Complete epithelial renewal every 3 to 5 days \u2014 among the fastest turnover rates in the body. This is why IECs are highly sensitive to any reduction in energy or substrate supply."
    },
    "molecular_mechanism": {
      "tight_junction_complex": {
        "components": "Claudins (claudin-1, 2, 3, 4, 5 \u2014 tissue specific expression), occludin, junctional adhesion molecules (JAMs), and ZO scaffold proteins (ZO-1, ZO-2, ZO-3)",
        "zinc_requirement": "ZO-1 and claudin-1 expression requires zinc. Zinc also required for occludin phosphorylation maintaining junction integrity. Zinc deficiency \u2192 looser tight junctions \u2192 increased permeability. Ref: NUT_ZINC_001",
        "butyrate_maintenance": "Butyrate (from BIO_MICROBIOME_001) \u2192 HDAC inhibition \u2192 upregulates claudin-3 and occludin expression \u2192 tighter junctions",
        "disruption_factors": "NSAIDs (inhibit COX-2 prostaglandins needed for mucosal repair). Alcohol (acetaldehyde disrupts claudin-1). Stress cortisol (downregulates tight junction proteins). Gluten (gliadin activates zonulin in susceptible individuals \u2192 tight junction opening)."
      },
      "leaky_gut_inflammatory_cascade": {
        "step_1": "Tight junction integrity compromised \u2192 paracellular permeability increases \u2192 bacterial lipopolysaccharide (LPS) from gram-negative bacteria translocates into portal circulation",
        "step_2": "LPS binds TLR-4 (with MD-2 coreceptor) on monocytes, macrophages, and Kupffer cells in liver \u2192 MyD88 adaptor \u2192 NF-kB activation \u2192 TNF-alpha, IL-6, IL-1beta secretion",
