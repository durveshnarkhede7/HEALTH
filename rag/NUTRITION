      "collagen_hydroxylation_support": "Prolyl hydroxylase also has some dependency on cofactor availability in the iron-linked metabolic network.",
      "immune_function": "Iron is required for myeloperoxidase in neutrophils and for NK cell cytotoxicity. Deficiency increases infection susceptibility."
    },
    "deficiency_chain": {
      "stage_1_storage_depletion": "Serum ferritin falls below 30 ng/mL — storage iron depleted. No symptoms yet.",
