  "BIO_SEBGLAND_001": {
    "id": "BIO_SEBGLAND_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Sebaceous Gland",
    "parent_system": "SYS_SKIN_001",
    "associated_with": "BIO_FOLLICLE_001",
    "definition": "Branched holocrine exocrine glands attached to the upper segment of the pilosebaceous unit, present across almost all body skin except palms and soles. Highest density on the face (400 to 900 per cm2 on forehead and nose), scalp, chest, and upper back \u2014 precisely the anatomical distribution of acne.",
    "function": "Secretes sebum \u2014 a complex lipid mixture \u2014 onto the skin surface and into the follicle. Sebum lubricates the hair shaft and skin, prevents transepidermal water loss from the follicle canal, maintains acid mantle pH, and provides antimicrobial protection via squalene and free fatty acids. Acts as a local paracrine signalling system \u2014 sebocytes produce neuropeptides and cytokines that influence neighbouring keratinocytes and follicle cells.",
    "cellular_mechanism": "Sebocytes are the specialised lipid-producing cells of the gland. They originate from sebaceous stem cells (CD34+/Blimp1+ expressing) at the gland periphery. As sebocytes mature they fill progressively with lipid droplets \u2014 visible on histology as vacuolated cells. At full maturation the sebocyte ruptures and releases its entire cytoplasmic contents \u2014 including the nucleus \u2014 as sebum. This holocrine secretion differentiates sebaceous glands from merocrine (eccrine) glands which secrete by exocytosis. Full sebocyte lifespan from stem cell to secretion is approximately 7 days.",
    "sebum_composition": {
      "triglycerides": "57 percent of total sebum",
      "wax_esters": "26 percent \u2014 unique to sebaceous secretion, not found elsewhere in body",
      "squalene": "12 percent \u2014 antioxidant precursor to cholesterol. When oxidised by UV, squalene peroxide is highly comedogenic",
      "free_fatty_acids": "5 percent \u2014 result of P. acnes lipase acting on triglycerides",
      "cholesterol_and_esters": "Remainder \u2014 structural and barrier components"
    },
    "molecular_mechanism": {
      "androgen_regulation": {
        "primary_driver": "Sebaceous glands are among the most androgen-sensitive tissues in the body. Sebocytes express androgen receptor (AR), 5-alpha reductase type 1 (converts testosterone to DHT locally), and 17beta-HSD enzymes for local androgen metabolism.",
        "signalling_cascade": "DHT or testosterone binds AR \u2192 AR nuclear translocation \u2192 binds androgen response elements \u2192 activates SREBP-1c (master lipogenic transcription factor) \u2192 upregulates FASN (fatty acid synthase), ACC (acetyl-CoA carboxylase), DGAT (diacylglycerol acyltransferase) \u2192 massive increase in fatty acid and triglyceride synthesis \u2192 sebum volume increases up to 5-fold",
        "DHT_potency": "DHT is 3 to 5 times more potent than testosterone at sebocyte AR \u2014 because DHT binds AR with higher affinity (Kd approximately 0.2 nM vs 1 nM for testosterone) and dissociates more slowly",
        "ref": "HOR_DHT_001"
      },
      "insulin_IGF1_pathway": {
        "mechanism": "Insulin and IGF-1 activate PI3K/Akt/mTORC1 independently of AR \u2192 mTORC1 phosphorylates SREBP-1 \u2192 same downstream lipogenesis as androgen pathway. Insulin and DHT therefore have additive sebum-stimulating effects.",
        "high_GI_diet_effect": "Dietary refined carbohydrates \u2192 glucose spike \u2192 insulin surge \u2192 IGF-1 elevation \u2192 sebocyte mTORC1 activation \u2192 sebum overproduction \u2192 acne. This explains the robust acne-diet relationship observed in epidemiological studies.",
        "ref": "HOR_INSULIN_001"
      },
      "acne_pathogenesis_cascade": {
        "step_1_sebum": "Androgen + insulin/IGF-1 driven sebum overproduction \u2014 follicle canal fills with sebum",
        "step_2_hyperkeratosis": "Androgen and IGF-1 also promote follicular keratinocyte proliferation and reduce normal desquamation \u2192 shed keratinocytes accumulate in follicle canal instead of being shed outward \u2192 microcomedone formation",
        "step_3_P_acnes": "Cutibacterium acnes (P. acnes) is an anaerobic commensal resident of the follicle. Excess sebum provides unlimited substrate \u2192 P. acnes proliferation within the blocked follicle \u2192 lipase enzyme converts sebum triglycerides to pro-inflammatory free fatty acids",
        "step_4_innate_immune": "Free fatty acids and P. acnes cell wall components (DAMPs and PAMPs) \u2192 activate TLR-2 and TLR-4 on surrounding keratinocytes and sebocytes \u2192 MyD88 signalling \u2192 NF-kB \u2192 IL-1beta, IL-6, IL-8, TNF-alpha secretion \u2192 neutrophil recruitment \u2192 inflammatory papule and pustule formation",
        "step_5_adaptive_immune": "CD4+ Th17 cells recognise P. acnes antigens \u2192 IL-17 \u2192 further keratinocyte inflammation and barrier disruption \u2192 nodular and cystic lesions in severe acne"
      },
      "gut_microbiome_connection": {
        "mechanism": "Gut dysbiosis \u2192 increased systemic LPS \u2192 TLR-4 on sebocytes and keratinocytes \u2192 basal NF-kB activation \u2192 lower threshold for inflammatory acne cascade",
        "ref": "BIO_MICROBIOME_001"
