  "BIO_MITOCHONDRIA_001": {
    "id": "BIO_MITOCHONDRIA_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Mitochondria",
    "parent_system": "SYS_ENERGY_001",
    "definition": "Double-membrane organelles of bacterial evolutionary origin, present in all nucleated human cells, generating 90 to 95 percent of cellular ATP through oxidative phosphorylation. Mitochondria are not static organelles \u2014 they form dynamic networks that fuse (mitochondrial fusion) and divide (fission) in response to energy demand, nutrient availability, and cellular stress.",
    "function": "Primary ATP production via oxidative phosphorylation. Regulation of apoptosis via cytochrome c release. Production of metabolic intermediates (steroid hormone precursors, haem, citrate for lipogenesis). Calcium homeostasis buffering. Thermogenesis (uncoupled respiration in brown adipose tissue). Detection of cellular stress and signalling via mitochondrial ROS.",
    "numbers_per_cell": {
      "liver_hepatocytes": "1000 to 2000 \u2014 high metabolic demand",
      "cardiac_muscle": "5000 \u2014 continuous energy demand",
      "hair_matrix_cells": "800 to 1500 \u2014 high due to rapid division rate",
      "red_blood_cells": "0 \u2014 mature RBCs have no mitochondria"
    },
    "cellular_mechanism": "The outer mitochondrial membrane is permeable to small molecules via porin channels. The inner membrane is completely impermeable \u2014 this impermeability is essential for maintaining the proton gradient. The inner membrane is extensively folded into cristae, dramatically increasing surface area for ETC complexes. In the matrix (aqueous interior), the Krebs cycle operates. The intermembrane space houses cytochrome c \u2014 both an electron carrier and, when released, a trigger for apoptosis. Mitochondrial dynamics (fusion and fission via Drp1, Mfn1/2, OPA1 proteins) allow cells to adjust mitochondrial network architecture \u2014 fragmentation during stress, elongation during energy-demanding states.",
    "molecular_mechanism": {
      "krebs_cycle": {
        "overview": "Acetyl-CoA (from glucose via pyruvate dehydrogenase, from fatty acid beta-oxidation, or from amino acid catabolism) enters cycle \u2192 8 reactions \u2192 regenerate oxaloacetate while releasing 2 CO2 \u2192 producing 3 NADH, 1 FADH2, 1 GTP per turn",
        "nutrient_dependency": "Pyruvate dehydrogenase requires thiamine (B1) and lipoic acid. Isocitrate dehydrogenase requires Mg2+ and ADP. Alpha-ketoglutarate dehydrogenase requires thiamine, lipoic acid, NAD+, CoA, and FAD.",
        "B_vitamin_roles": "B1, B2, B3, B5 are all essential Krebs cycle cofactors. These B vitamins are often grouped as the 'energy B vitamins' \u2014 their deficiency causes fatigue at the cellular level."
      },
      "oxidative_phosphorylation": "See BIO_ETC_001 for full Complex I-V detail. Net yield from 1 glucose via complete oxidation: 30 to 32 ATP molecules. Compare to anaerobic glycolysis: only 2 ATP. The difference explains why iron deficiency (which impairs ETC) creates profound fatigue.",
      "iron_absolute_requirement": {
        "mechanism": "Haem groups (Fe2+ embedded in porphyrin ring) are structural components of Complexes I, II, III, and cytochrome c. Iron-sulphur clusters [Fe-S] in Complex I, II, and III carry electrons between metal centres. Without adequate iron, these centres are incomplete \u2192 electron transfer inefficiency \u2192 reduced proton pumping \u2192 reduced ATP synthesis per glucose molecule",
        "clinical_manifestation": "Iron deficiency reduces cellular ATP yield before haemoglobin falls \u2014 explaining why iron-deficient patients feel fatigue before developing anaemia",
        "ref": "NUT_IRON_001"
      },
      "magnesium_ATP_complex": {
        "mechanism": "Biologically active ATP exists as the Mg-ATP2- complex \u2014 magnesium chelates the gamma and beta phosphate groups of ATP, stabilising the molecule and making it the correct substrate for ATPases",
        "ATP_synthase": "Complex V (ATP synthase) catalytic mechanism requires Mg2+ for phosphoryl transfer from ADP to ATP. Mg2+ also stabilises the F1 subunit catalytic site conformation.",
        "cellular_consequence": "Magnesium deficiency \u2192 non-chelated ATP \u2192 cannot be utilised by cellular ATPases \u2192 functional energy deficiency despite adequate glucose and oxygen \u2192 fatigue, muscle cramps, cardiovascular dysrhythmia",
        "ref": "NUT_MAGNESIUM_001"
      },
      "CoQ10_mobile_carrier": {
        "role": "Coenzyme Q10 (ubiquinone) is the lipid-soluble mobile electron carrier in the inner mitochondrial membrane. Carries electrons from Complex I and Complex II to Complex III. Also functions as the primary membrane-bound antioxidant, accepting electrons from superoxide before ROS can damage membrane lipids.",
        "tissue_levels": "CoQ10 is highest in heart, liver, kidney, skeletal muscle \u2014 tissues with highest mitochondrial density. Synthesis declines with age from peak at age 20.",
        "statin_reduction": "HMG-CoA reductase inhibitors (statins) block the same mevalonate pathway used to synthesise CoQ10 \u2014 explaining statin-associated muscle fatigue",
        "ref": "NUT_COENZYME_001"
      },
      "thyroid_mitochondrial_regulation": {
        "mechanism": "T3 binds mitochondrial T3 receptors \u2192 upregulates biogenesis of Complex I, III, IV, and V \u2192 increases total mitochondrial mass \u2192 increases basal metabolic rate",
        "hypothyroid_effect": "Low T3 \u2192 reduced ETC complex expression \u2192 fewer proton pumps \u2192 lower ATP production rate \u2192 reduced BMR \u2192 fatigue, cold intolerance, weight gain",
        "ref": "HOR_THYROID_001"
      },
      "ROS_production": "Complexes I and III are the primary sites of superoxide (O2-) generation \u2014 electrons leak from the ETC and reduce O2. Under normal conditions antioxidant enzymes (SOD, catalase, GPx) neutralise superoxide. When ETC is damaged or nutrients depleted \u2192 electron leak increases \u2192 oxidative stress \u2192 mitochondrial membrane damage \u2192 apoptosis trigger",
      "B_complex_energy_production": {
        "mechanism": "The B-Complex vitamins are non-negotiable cofactors for mitochondrial energy production. B1 (Thiamine), B2 (Riboflavin), and B3 (Niacin) are required for the Pyruvate Dehydrogenase complex to convert glycolysis products into Acetyl-CoA. B5 (Pantothenic Acid) forms the CoA structure itself. B6 (Pyridoxine) is needed for amino acid entry into the Krebs cycle. Without the full B-complex, ATP production halts, leading to profound cellular fatigue.",
        "refs": [
          "NUT_B1_001",
