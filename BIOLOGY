    "tags": ["gut microbiome", "Faecalibacterium prausnitzii", "Akkermansia muciniphila", "Lactobacillus", "Bifidobacterium", "butyrate", "propionate", "acetate", "SCFA", "estrobolome", "serotonin", "gut-skin axis", "gut-brain axis", "Treg", "Th17", "LPS", "dysbiosis", "iron absorption", "zinc absorption"]
