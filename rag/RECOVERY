    "node_type": "recovery_modality",
    "version": "1.0",
    "name": "Cold Exposure / Ice Baths",
    "mechanism": "Acute cold shock causes rapid vasoconstriction (flushing out metabolic waste like lactic acid), followed by a massive release of Norepinephrine (improving focus and mood). Reduces acute inflammation and activates Brown Adipose Tissue (BAT) for thermogenesis.",
    "impacts": ["REC_MUSCLE_001", "SYS_INFLAMMATION_001", "SYS_METABOLIC_001"],
    "dependencies": []
  },
