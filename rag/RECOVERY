  "REC_FOLLICLE_001": {
    "id": "REC_FOLLICLE_001",
    "node_type": "recovery_timeline",
    "version": "1.0",
    "name": "Hair Follicle Recovery Timeline",
    "expected_duration": "3 to 6 months minimum",
    "biological_bottleneck": "Hair operates in distinct phases. Once a stressor pushes hair into the Telogen (resting) phase, it remains dormant for ~100 days before falling out. A new Anagen (growth) phase cannot begin until this cycle completes. Visible density improvement takes 6+ months due to the average growth rate of 1cm per month.",
    "required_nutrients": ["NUT_IRON_001", "NUT_PROTEIN_001", "NUT_VITD_001", "NUT_ZINC_001"],
    "disruptors": ["STR_CHRONIC_001", "HOR_CORTISOL_001", "HOR_DHT_001", "INF_CHRONIC_001"],
    "associated_systems": ["SYS_HAIR_001", "BIO_FOLLICLE_001"]
  },
  "REC_SKIN_001": {
    "id": "REC_SKIN_001",
    "node_type": "recovery_timeline",
    "version": "1.0",
    "name": "Skin/Epidermal Turnover Timeline",
    "expected_duration": "28 to 40 days",
    "biological_bottleneck": "Stem cells in the basal layer must divide, migrate upwards through the stratum spinosum and granulosum, keratinise, and finally shed (desquamation). This turnover rate slows dramatically with age (can take up to 60 days post-menopause).",
    "required_nutrients": ["NUT_VITC_001 (Collagen)", "NUT_ZINC_001", "NUT_OMEGA3_001"],
    "disruptors": ["HOR_CORTISOL_001 (Degrades collagen)", "HOR_IGF1_001 (Causes hyper-keratinisation)"],
    "associated_systems": ["SYS_SKIN_001", "BIO_EPIDERMIS_001", "BIO_DERMIS_001"]
  },
  "REC_GUT_001": {
    "id": "REC_GUT_001",
    "node_type": "recovery_timeline",
    "version": "1.0",
    "name": "Gut Lining & Microbiome Recovery",
    "expected_duration": "3-5 days (lining), 3-6 months (microbiome)",
    "biological_bottleneck": "The intestinal epithelial cells (enterocytes) have the fastest turnover in the body (3-5 days). However, healing Leaky Gut requires closing tight junctions, and rebuilding a depleted mucosal layer and diverse microbiome takes months of sustained prebiotic feeding and stress removal.",
    "required_nutrients": ["NUT_PROTEIN_001 (Specifically L-Glutamine)", "NUT_ZINC_001 (Tight junctions)"],
    "disruptors": ["STR_CHRONIC_001", "GUT_DYSBIOSIS_001", "MEDS_ANTIBIOTICS_001"],
    "associated_systems": ["SYS_DIGESTIVE_001", "BIO_GUTLINING_001", "BIO_MICROBIOME_001"]
  },
  "REC_MUSCLE_001": {
    "id": "REC_MUSCLE_001",
    "node_type": "recovery_timeline",
    "version": "1.0",
    "name": "Muscle & Connective Tissue Recovery",
    "expected_duration": "48-72 hours (muscle), 3-6 months (tendons/ligaments)",
    "biological_bottleneck": "Muscle tissue has massive blood supply and satellite cells, allowing rapid repair. Connective tissues (tendons/ligaments) are virtually avascular, meaning nutrient delivery is painfully slow, requiring months to remodel collagen matrices after injury.",
    "required_nutrients": ["NUT_PROTEIN_001", "NUT_VITC_001 (Collagen cross-linking)"],
    "disruptors": ["SLP_DEPRIVATION_001", "OXI_STRESS_001"],
    "associated_systems": ["SYS_MUSCULOSKELETAL_001", "BIO_MUSCLE_001", "BIO_BONE_001"]
  },
