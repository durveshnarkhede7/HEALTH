  "BIO_MICROBIOME_001": {
    "id": "BIO_MICROBIOME_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Gut Microbiome",
    "parent_system": "SYS_DIGESTIVE_001",
    "definition": "The collective community of approximately 38 trillion microorganisms — primarily bacteria but also archaea, fungi (mycobiome), viruses (virome), and protozoa — residing throughout the gastrointestinal tract with highest density in the colon (10^11 to 10^12 per mL). Collectively encodes 150 times more unique genes than the human genome. Functionally operates as a metabolic organ with body weight-equivalent metabolic output.",
    "function": "Synthesises vitamins K2, B2 (riboflavin), B7 (biotin), B9 (folate), and contributes to B12 in the colon (though colonic B12 is poorly absorbed). Ferments non-digestible dietary fibre → short-chain fatty acids (SCFAs: butyrate, propionate, acetate). Trains and calibrates the immune system — 70 to 80 percent of immune cells reside in gut-associated lymphoid tissue (GALT) and are educated by microbiome interactions. Metabolises estrogens via the estrobolome. Produces neuroactive compounds. Maintains gut barrier integrity. Modulates systemic inflammation.",
    "ecological_structure": {
      "dominant_phyla": {
        "Firmicutes": "50 to 60 percent of bacteria — includes Lactobacillus, Ruminococcus, Clostridium, Faecalibacterium prausnitzii",
        "Bacteroidetes": "20 to 30 percent — includes Bacteroides, Prevotella",
        "Actinobacteria": "5 to 10 percent — includes Bifidobacterium",
        "Proteobacteria": "Less than 5 percent normally — overgrowth indicates dysbiosis"
      },
      "key_beneficial_species": {
        "Faecalibacterium_prausnitzii": "Single most abundant commensal in healthy gut. Primary butyrate producer. Anti-inflammatory via butyrate and direct NLRP3 inflammasome inhibition. Dramatically reduced in IBD, IBS, obesity.",
        "Akkermansia_muciniphila": "Mucin-degrading species. Degrades outer mucus layer stimulating goblet cell mucin replenishment. Inversely correlated with obesity and insulin resistance. Modulates GLP-1 secretion.",
        "Lactobacillus_rhamnosus": "Produces lactic acid. Reduces intestinal pH inhibiting pathogens. Shown to reduce cortisol response and anxiety behaviour in mouse models via vagal GABA signalling.",
        "Bifidobacterium_longum": "Primary carbohydrate fermenter. Reduces intestinal pH. Produces GABA. Reduces systemic inflammation.",
        "Roseburia_intestinalis": "Major butyrate producer. Reduces colonic pH. Improves insulin sensitivity."
      }
    },
    "molecular_mechanism": {
      "SCFA_production": {
        "butyrate": {
          "producers": "Faecalibacterium prausnitzii, Roseburia, Eubacterium hallii",
          "mechanism": "Bacterial beta-oxidation of acetate → butyryl-CoA → butyrate",
          "colonocyte_fuel": "Butyrate provides 60 to 70 percent of colonocyte energy requirement via beta-oxidation in mitochondria",
          "tight_junction": "Butyrate activates HDAC inhibition → increased claudin-3 and occludin expression → tighter tight junctions → reduced intestinal permeability",
          "anti_inflammatory": "HDAC inhibition → suppresses NF-kB → reduces IL-6, TNF-alpha, IL-1beta. Activates GPR109a receptor on colonocytes and immune cells → anti-inflammatory signalling",
          "gut_skin_axis": "Butyrate reduces LPS translocation → lower systemic inflammation → reduced skin inflammation and acne"
        },
        "propionate": {
          "producers": "Bacteroides, Akkermansia, Ruminococcus",
          "role": "Transported to liver → gluconeogenic substrate (30 to 40 percent of hepatic glucose synthesis). Inhibits cholesterol synthesis in liver. Activates PPAR-gamma in adipose → improved insulin sensitivity.",
          "satiety": "Propionate → stimulates PYY and GLP-1 from L cells → reduces appetite → weight regulation"
        },
        "acetate": {
          "producers": "Bifidobacterium, Prevotella",
          "role": "Crosses blood-brain barrier → hypothalamic satiety signalling. Substrate for butyrate production by cross-feeding bacteria. Provides energy for peripheral tissues.",
          "majority_SCFA": "Acetate represents 60 percent of total SCFAs produced"
        }
      },
      "estrobolome": {
        "definition": "The subset of gut microbiome genes encoding beta-glucuronidase and related enzymes that metabolise oestrogens in the gut",
        "mechanism": "Estrogens conjugated (glucuronidated) in liver → secreted in bile → enter colon → beta-glucuronidase from specific bacteria deconjugates them → free estrogens reabsorbed into portal circulation → enterohepatic estrogen recirculation",
        "dysbiosis_consequence": "Reduced microbial diversity → reduced estrobolome activity → altered estrogen recirculation → can contribute to estrogen deficiency (if deconjugation reduced) or estrogen excess (if different microbial species alter ratio). Relevant to PCOS, hormonal acne, and menopausal symptoms.",
        "ref": "HOR_ESTROGEN_001"
      },
      "immune_training": {
        "mechanism": "Commensal bacteria and their metabolites present to dendritic cells and macrophages in the lamina propria → pattern recognition via TLRs → education of T cell populations",
        "Treg_induction": "Bacteroides fragilis polysaccharide A and Clostridia metabolites → induce FoxP3+ regulatory T cells → systemic immune tolerance",
        "Th17_balance": "Dysbiosis → Th17 over Treg → increased susceptibility to autoimmune and inflammatory conditions including Hashimoto's, IBD, psoriasis",
        "timing": "First 1000 days of life are critical — microbiome composition during this window shapes lifetime immune calibration"
      },
      "serotonin_production": {
        "mechanism": "Enterochromaffin cells (EC cells) in gut mucosa synthesise 90 to 95 percent of total body serotonin from tryptophan via tryptophan hydroxylase",
        "microbiome_role": "Short-chain fatty acids and bile acids produced by gut bacteria directly stimulate EC cell serotonin synthesis. Gut Lactobacillus and Bifidobacterium species regulate tryptophan → serotonin pathway.",
        "gut_motility": "Serotonin acts on enteric nervous system 5-HT3 and 5-HT4 receptors → coordinates peristaltic reflex → gut motility. Reduced gut serotonin (from dysbiosis) → constipation — common in IBS and hypothyroidism.",
        "mood_connection": "Gut serotonin does not cross blood-brain barrier. However, gut microbiome also produces tryptophan-derived metabolites that do enter brain — plus signals via vagal afferents. The gut-brain axis modulates mood and cognition."
      },
      "nutrient_absorption_impact": {
        "iron": "Microbial short-chain fatty acids reduce colonic pH → promotes Fe3+ reduction to Fe2+ → enhances non-haem iron solubility and absorption via DMT-1. Dysbiosis → higher pH → reduced iron absorption. Ref: ABS_IRON_001",
        "zinc": "Gut microbiome influences zinc bioavailability via phytate metabolism. Lactobacillus species produce phytase enzyme → reduces phytate → increases zinc absorption. Ref: ABS_ZINC_001",
        "vitamin_K2": "Bacteroides and Prevotella produce menaquinones (K2) — absorbed from colon. Required for gamma-carboxylation of bone proteins and clotting factors."
      }
    },
    "gut_axes_detailed": {
      "gut_skin_axis": {
        "mechanism": "Dysbiosis → leaky gut (BIO_GUTLINING_001) → LPS translocation → systemic inflammation (INF_CHRONIC_001) → skin inflammation → acne, rosacea, psoriasis, eczema. Also: altered microbiome → altered sebaceous gland microenvironment → P. acnes community changes → altered acne risk.",
        "pathway_ref": "PATH_GUT_ACNE_001"
      },
      "gut_brain_axis": {
        "mechanism": "Microbiome → SCFAs and neuroactive metabolites → vagal afferent stimulation → brainstem → limbic system. Direct metabolite (GABA, tryptophan metabolites) entry into portal circulation → blood-brain barrier crossing.",
        "clinical_manifestation": "Dysbiosis associated with anxiety, depression, cognitive impairment, brain fog — see SYM_BRAINFOG_001"
      },
      "gut_hormone_axis": {
        "mechanism": "Estrobolome → estrogen recirculation. Microbiome → GLP-1 secretion → insulin sensitivity. Microbiome → SCFAs → PPAR-gamma → adipose insulin sensitivity.",
        "PCOS_connection": "Dysbiosis in PCOS patients — reduced microbial diversity, altered estrobolome, increased LPS → increased systemic androgen → worsens PCOS. Bidirectional relationship."
      },
      "gut_hair_axis": {
        "mechanism": "Malabsorption from gut dysbiosis → all hair-critical nutrient deficiencies simultaneously (iron, zinc, B12, protein) → convergent multifactorial hair loss",
        "pathway_ref": "PATH_IRON_HAIR_001"
      }
    },
    "cross_system_connections": {
      "to_hair_system": "Via nutrient malabsorption (BIO_GUTLINING_001) and systemic inflammation. Gut health is foundational to hair health.",
      "to_skin_system": "Gut-skin axis — dysbiosis → systemic LPS → cutaneous inflammation (BIO_EPIDERMIS_001 and BIO_SEBGLAND_001)",
      "to_hormonal_system": "Estrobolome regulation (HOR_ESTROGEN_001). GLP-1 regulation (HOR_INSULIN_001 feedback).",
      "to_immune_system": "70 percent of immune cells educated by gut microbiome"
