  "BIO_DERMALPAPILLA_001": {
    "id": "BIO_DERMALPAPILLA_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Dermal Papilla",
    "parent_system": "SYS_HAIR_001",
    "parent_structure": "BIO_FOLLICLE_001",
    "definition": "A compact cluster of 150 to 300 specialised mesenchymal fibroblast-like cells at the base of the hair follicle, encased within the hair bulb, forming the primary signalling command centre. The dermal papilla is the brain of the hair follicle — every instruction to grow, maintain, regress, or miniaturise originates here.",
    "function": "Secretes paracrine growth factors and inhibitory signals to matrix cells and bulge stem cells, controlling cycle phase, hair shaft diameter, and anagen duration. Expresses androgen receptors — the site where DHT executes androgenetic alopecia. Directs vascular supply to the matrix via VEGF-driven angiogenesis. Maintains inductive capacity — can regenerate a complete new follicle when transplanted.",
    "cellular_mechanism": "Dermal papilla cells are unlike any other fibroblast population — they retain embryonic inductive properties throughout life. They survive catagen within a condensed cluster and guide the bulge stem cells to reconstruct the lower follicle at the start of each new anagen. Their number correlates with hair shaft diameter — larger papilla → thicker hair shaft. In androgenetic alopecia, progressive papilla volume reduction produces progressively thinner shafts.",
    "molecular_mechanism": {
      "anagen_promotion_signals": {
        "Wnt3a_Wnt10b": "Secreted by DP → stabilise beta-catenin in bulge stem cells → TCF4/LEF-1 transcription → stem cell activation",
        "IGF1": "Secreted by DP → binds IGF-1R on matrix keratinocytes → PI3K/Akt → survival, proliferation, anagen maintenance",
        "FGF7_FGF10": "KGF family secreted by DP → bind FGFR2b on matrix keratinocytes → proliferation and differentiation maintenance",
        "FGF2": "Basic FGF secreted by DP → anti-apoptotic for matrix cells → anagen prolongation",
        "VEGF": "Secreted by DP → binds VEGFR2 on endothelial cells → capillary formation → nutrient delivery to matrix"
      },
      "androgen_damage_cascade": {
        "step_1": "DHT from systemic circulation or local 5-alpha reductase (type 2) conversion in DP cells binds androgen receptor (AR)",
        "step_2": "AR-DHT complex translocates to nucleus → upregulates TGF-beta-2 gene transcription",
        "step_3": "TGF-beta-2 secreted into pericellular space → binds TGFBR2 on matrix keratinocytes → SMAD2/3 phosphorylation → growth arrest and apoptosis",
        "step_4": "AR-DHT also upregulates DKK-1 (Dickkopf-1) → Wnt receptor antagonist → blocks beta-catenin signalling → stem cell activation fails",
        "step_5": "Each cycle with DHT exposure → shorter anagen, smaller papilla volume, thinner shaft → progressive miniaturisation",
        "ar_expression_genetics": "AR gene on X chromosome — inherited from maternal grandfather explains male pattern inheritance. Number of CAG repeats in AR gene determines AR sensitivity — fewer repeats → higher sensitivity → more susceptible to miniaturisation at normal DHT levels"
      },
      "mechanotransduction": {
        "mechanism": "Mechanical tension applied to DP cells (scalp massage) → PIEZO1 and PIEZO2 mechanosensitive ion channels open → calcium influx → activation of FAK and YAP signalling → increased DP cell IGF-1 and Wnt secretion → enhanced anagen promotion",
        "evidence": "2016 standardised scalp massage study (Koyama et al) — 4 minutes daily over 24 weeks → increased hair shaft diameter in all participants",
        "intervention_ref": "INT_DHT_001"
      },
      "cortisol_effect": "Glucocorticoid receptor in DP → cortisol binding → upregulates DKK-2 and activin A → inhibit Wnt and IGF-1 → premature catagen signalling. Separate from DHT pathway — stress-induced hair loss operates independently of androgen excess.",
      "PDGF_signalling": "PDGF-AA and PDGF-BB from DP → maintain DP cell survival during catagen as lower follicle undergoes apoptosis. PDGF also recruits DP cells to the new anagen follicle reconstruction site."
    },
    "papilla_volume_and_hair_diameter": {
      "relationship": "Hair shaft cross-sectional diameter is directly proportional to dermal papilla cell number. Each 1000-cell reduction in DP size reduces shaft diameter by approximately 10 micrometers.",
      "miniaturisation_definition": "When terminal hair follicle DP volume falls below 40 percent of original → follicle produces vellus hair only → clinically invisible hair shaft"
    },
    "cross_system_connections": {
      "to_hormonal_system": "Primary target of HOR_DHT_001. Also responds to HOR_CORTISOL_001, HOR_IGF1_001, HOR_ESTROGEN_001.",
      "to_energy_system": "DP cells require ATP for continuous paracrine signalling. Mitochondrial dysfunction reduces DP signal output.",
      "to_genetics": "GEN_ANDROGEN_SENSITIVITY_001 determines DP androgen receptor expression level — the genetic basis of alopecia susceptibility."
    },
    "damage_pathways": {
