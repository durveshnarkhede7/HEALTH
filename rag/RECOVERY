  "REC_SLEEP_001": {
    "id": "REC_SLEEP_001",
    "node_type": "recovery_modality",
    "version": "1.0",
    "name": "Deep Sleep Repair",
    "mechanism": "The ultimate recovery state. During NREM Stage 3 (Slow-Wave Sleep), brain waves slow, cortisol drops, and the pituitary gland releases ~70% of the body's daily Growth Hormone (GH). This GH pulse is the absolute requirement for repairing muscle, skin, and hair follicles.",
    "impacts": ["REC_FOLLICLE_001", "REC_MUSCLE_001", "REC_SKIN_001"],
    "dependencies": ["SLP_DEEPSLEEP_001"]
  },
