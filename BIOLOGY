      "relationship_to_gut": "BIO_MICROBIOME_001"
    },
    "immune_privilege": {
      "definition": "The lower anagen follicle is an immune-privileged site — it expresses low levels of MHC class I molecules, high levels of immunosuppressive factors (TGF-beta-1, alpha-MSH, CGRP), and is surrounded by immunosuppressive CD4+ T regulatory cells",
      "purpose": "Prevents autoimmune attack on the genetically foreign hair shaft (which contains paternal antigens)",
      "breakdown_consequence": "Loss of immune privilege → CD8+ T cell infiltration of the follicle → alopecia areata — see MED_ALOPECIA_001"
