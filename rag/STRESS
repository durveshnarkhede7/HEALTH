    "node_type": "stress",
    "version": "1.0",
    "name": "Circadian Disruption Stress",
    "definition": "Living out of sync with the natural light-dark cycle (shift work, severe jet lag, staying up very late).",
    "indian_context": "Massive BPO/IT sector working US/UK shifts. Late-night smartphone usage.",
    "biological_mechanism": "Misalignment between the central SCN clock (brain) and peripheral clocks (liver, gut, muscle). Results in eating when insulin sensitivity is lowest.",
    "hormonal_impacts": [
      "HOR_MELATONIN_001 (Suppressed)",
      "HOR_INSULIN_001 (Severe nocturnal insulin resistance)",
      "HOR_CORTISOL_001 (Reversed curve - high at night, low in morning)"
    ],
    "gut_impacts": [
      "GUT_DYSBIOSIS_001 (Microbiome has its own circadian rhythm which gets destroyed)"
    ],
    "sleep_impacts": [
      "SLP_CIRCADIAN_001",
      "SLP_DEPRIVATION_001"
    ],
