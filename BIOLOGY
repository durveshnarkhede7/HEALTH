  "BIO_ETC_001": {
    "id": "BIO_ETC_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Electron Transport Chain",
    "parent_system": "SYS_ENERGY_001",
    "parent_structure": "BIO_MITOCHONDRIA_001",
    "definition": "A series of five protein complexes (Complex I through V) embedded in the inner mitochondrial membrane that transfer electrons from NADH and FADH2 through a chain of redox carriers to molecular oxygen, generating a transmembrane proton gradient (chemiosmotic potential) that drives ATP synthesis.",
    "function": "Harvests the energy stored in NADH and FADH2 (from Krebs cycle) and converts it into an electrochemical proton gradient across the inner mitochondrial membrane. This gradient drives ATP synthase (Complex V) to phosphorylate ADP to ATP — the universal energy currency of the cell. Final electron acceptor is O2 → reduced to H2O.",
    "complexes_detailed": {
      "complex_I": {
        "name": "NADH:ubiquinone oxidoreductase",
        "function": "Accepts 2 electrons from NADH → transfers to ubiquinone (CoQ10) → pumps 4 protons across inner membrane",
        "structure": "L-shaped. 45 subunits. Contains 8 iron-sulphur (Fe-S) clusters and 1 FMN cofactor.",
        "iron_dependency": "Fe-S clusters are the electron relay chain within Complex I. Iron deficiency → incomplete Fe-S cluster assembly → reduced Complex I activity → reduced NADH oxidation rate → ATP deficit + increased electron leak → increased ROS"
      },
      "complex_II": {
        "name": "Succinate dehydrogenase",
        "function": "Connects Krebs cycle to ETC — oxidises succinate to fumarate → FADH2 → CoQ10. Does NOT pump protons.",
        "structure": "4 subunits. Contains 3 Fe-S clusters, 1 FAD cofactor, 1 haem b.",
        "iron_dependency": "Fe-S clusters required for electron transfer. Haem b is structural. Mutations in SDHB/C/D cause paragangliomas — demonstrating biological importance."
      },
      "complex_III": {
        "name": "Cytochrome bc1 complex",
        "function": "Transfers electrons from CoQ10 to cytochrome c → pumps 4 protons across inner membrane via Q-cycle mechanism",
        "structure": "11 subunits. Contains 2 haem b groups, 1 haem c1, 1 Rieske Fe-S cluster.",
        "iron_dependency": "Haem groups and Rieske Fe-S cluster all contain iron. Iron deficiency → impaired Complex III → bottleneck in electron flow → backup → increased superoxide generation at Complex I/III"
      },
      "complex_IV": {
        "name": "Cytochrome c oxidase",
        "function": "Terminal electron acceptor — reduces O2 to H2O. Pumps 2 protons per 2 electrons transferred.",
        "structure": "13 subunits in humans. Contains 3 copper centres (CuA, CuB, CuZ), 2 haem groups (haem a, haem a3), and 1 Mg2+ and 1 Zn2+ structural ion.",
        "copper_dependency": "CuA (in cytochrome c binding site) and CuB (in binuclear centre with haem a3 — the actual O2 reduction site) are catalytically essential. Copper deficiency → impaired Complex IV → reduced oxygen utilisation → cellular hypoxia despite normal O2 supply. Ref: NUT_COPPER_001"
      },
      "complex_V": {
        "name": "ATP synthase (F0F1-ATPase)",
        "function": "Uses proton gradient to phosphorylate ADP → ATP. F0 subunit in membrane rotates driven by proton flow. F1 subunit in matrix catalyses phosphorylation.",
        "structure": "F0 ring (10 c-subunits) + F1 headpiece (alpha3beta3gammadeltaepsilon). Rotary motor — among the smallest motors in nature.",
        "magnesium_requirement": "Mg2+ is required at the catalytic beta subunit for the phosphoryl transfer reaction. Without Mg2+, ATP synthesis rate drops significantly. Ref: NUT_MAGNESIUM_001"
      }
    },
    "proton_gradient_physiology": {
      "electrochemical_potential": "Approximately 180 mV across inner mitochondrial membrane — maintained by Complexes I, III, IV pumping protons to intermembrane space",
      "uncoupling": "Brown adipose tissue mitochondria express UCP1 (uncoupling protein) — allows protons back into matrix without passing through ATP synthase → proton gradient dissipated as heat → thermogenesis. Thyroid hormone upregulates UCP expression — mechanism of thyroid-controlled thermogenesis."
    },
    "ROS_generation_sites": {
      "complex_I_III": "Primary superoxide generation sites — electron leak at FMN site (Complex I) and ubisemiquinone site (Complex III)",
      "consequences": "O2- → SOD converts to H2O2 → catalase/GPx converts to H2O (normal). Overwhelmed → lipid peroxidation, protein carbonylation, mtDNA mutation",
      "iron_deficiency_amplification": "Iron deficiency → incomplete Fe-S clusters → electrons back up at Complex I/III → increased electron leak → increased ROS despite reduced total electron throughput — a paradox that worsens the oxidative environment"
    },
    "cross_system_connections": {
      "to_hair_system": "ATP from ETC powers matrix cell division (BIO_MATRIX_001). ETC impairment = hair loss.",
      "to_immune_system": "Immune cells (lymphocytes, macrophages) are among the most mitochondrially active cells — ETC impairment reduces immune capacity"
    },
    "damage_pathways": {
      "nutritional": ["NUT_IRON_001", "NUT_COPPER_001", "NUT_MAGNESIUM_001"],
      "oxidative": ["OXI_FREE_RADICAL_001"]
    },
    "tags": ["electron transport chain", "Complex I through V", "ATP synthesis", "iron-sulphur clusters", "haem", "cytochrome", "proton gradient", "chemiosmosis", "CoQ10", "copper", "magnesium", "ROS", "superoxide"]
  },
  "BIO_THYROID_001": {
    "id": "BIO_THYROID_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Thyroid Gland",
    "parent_system": "SYS_HORMONAL_001",
    "definition": "A butterfly-shaped bilobed endocrine gland at the anterior base of the neck, weighing 25 to 30 grams in adults, composed of approximately 3 million spherical follicles. The thyroid is the master regulator of metabolic rate — every cell in the body with mitochondria responds to thyroid hormones, making thyroid status the single most important systemic hormonal variable for hair, skin, energy, and weight.",
    "function": "Produces thyroxine (T4) and triiodothyronine (T3) — the master metabolic hormones. T3 is the active form acting at nuclear receptors to regulate transcription of genes governing mitochondrial biogenesis, basal metabolic rate, protein synthesis rate, cardiac rate and contractility, thermoregulation, gut motility, and differentiation of all rapidly dividing tissues including hair matrix, gut epithelium, and immune cells.",
    "follicular_structure": {
      "thyrocytes": "Cuboidal epithelial cells lining each follicle. Express TSH receptor (TSHR). Contain sodium-iodide symporter (NIS) on basolateral membrane for active iodide transport. Express thyroglobulin and thyroid peroxidase genes.",
      "colloid": "Central space of each follicle filled with thyroglobulin — the glycoprotein storage form of thyroid hormones. Iodinated thyroglobulin contains hundreds of MIT, DIT, T3, and T4 residues in peptide linkage.",
      "C_cells": "Parafollicular C cells between follicles — produce calcitonin for calcium regulation (separate from T3/T4 biology)."
    },
    "cellular_mechanism": "TSH from the pituitary binds TSHR on thyrocyte basolateral membrane → Gs protein → adenylyl cyclase → cAMP → PKA → stimulates NIS expression and iodide uptake, thyroglobulin synthesis, TPO activity, and thyroid hormone release. Endocytosis of colloid → lysosomal proteolysis of thyroglobulin → T3 and T4 released into circulation.",
    "molecular_mechanism": {
      "iodide_uptake_and_organification": {
        "step_1": "Iodide (I-) actively transported into thyrocyte via NIS (sodium-iodide symporter — Na+/I- cotransporter) on basolateral membrane. NIS requires sodium gradient maintained by Na/K-ATPase.",
        "step_2": "I- transported to apical membrane → pendrin channel releases I- into follicular lumen",
        "step_3": "Thyroid peroxidase (TPO) — a haem iron enzyme — oxidises I- to reactive iodine species using H2O2 as oxidant",
        "step_4": "Reactive iodine iodinated onto tyrosine residues of thyroglobulin → monoiodotyrosine (MIT) and diiodotyrosine (DIT)",
        "step_5": "TPO catalyses coupling reactions — DIT + DIT → T4 (tetraiodothyronine). MIT + DIT → T3 (triiodothyronine). These remain as peptide bonds within thyroglobulin in the colloid.",
        "TPO_iron_haem": "TPO absolutely requires haem Fe2+ for its peroxidase catalytic cycle. Iron deficiency → impaired TPO → reduced organification efficiency → reduced T4 synthesis. This is a direct molecular link between iron status and thyroid function. Ref: NUT_IRON_001"
      },
      "T4_to_T3_conversion": {
        "deiodinases": "Three deiodinase enzymes (D1 in liver/kidney/thyroid, D2 in brain/pituitary/muscle, D3 in fetal tissues/placenta) catalyse removal of iodine atoms from T4 and T3",
        "D2_activation": "D2 converts T4 → T3 (active). D2 is the primary T3-generating enzyme in peripheral tissues and the pituitary (where it regulates TSH feedback). D2 is selenium-dependent.",
        "D3_inactivation": "D3 converts T4 → reverse T3 (rT3 — biologically inactive) and T3 → T2. D3 upregulation by cortisol and IL-6 (inflammation) diverts T4 away from active T3 → sick euthyroid syndrome / low T3 syndrome",
        "selenium_requirement": "Both D1 and D2 are selenoproteins — they contain selenocysteine in their active sites. Selenium deficiency → impaired T4 to T3 conversion → hypothyroid symptoms with normal TSH. Ref: NUT_SELENIUM_001",
        "inflammation_block": "TNF-alpha and IL-6 from systemic inflammation → NF-kB → D3 upregulation + D2 downregulation → reduced T3 generation → all symptoms of hypothyroidism with potentially normal TSH. This is why chronically stressed, inflamed individuals present with subclinical hypothyroid symptoms."
      },
      "TSH_negative_feedback": {
        "pathway": "Hypothalamus TRH → pituitary TSH → thyroid T3/T4 → T3 feeds back to inhibit both TRH and TSH secretion",
        "pituitary_T3": "Pituitary TSH cells rely on intracellular T3 generated by D2 from circulating T4 — not directly from plasma T3. Therefore pituitary TSH suppression lags behind peripheral T3 recovery.",
        "clinical_interpretation": "TSH above 2.5 mIU/L with symptoms = subclinical hypothyroid. TSH above 4.5 = overt primary hypothyroidism. TSH normal but FT3 low = conversion problem (selenium, inflammation, cortisol)."
      },
      "autoimmune_hashimotos": {
        "trigger": "Molecular mimicry (viral antigens resembling TPO or thyroglobulin), Vitamin D deficiency (reduces regulatory T cell activity), genetic susceptibility (HLA-DR3, -DR5 haplotypes)",
        "mechanism": "Antigen-presenting cells present TPO or thyroglobulin peptides → activate Th1 CD4+ T cells → IFN-gamma → macrophage activation → thyrocyte destruction. B cells produce anti-TPO and anti-thyroglobulin antibodies — these serve as biomarkers and also contribute to complement-mediated thyrocyte lysis.",
        "progression": "Hashimoto's → initially may cause transient hyperthyroid (hashitoxicosis — thyroglobulin released by dying cells) → then progressive hypothyroidism over years to decades",
        "Vitamin_D_connection": "Vitamin D receptor (VDR) in regulatory T cells — VDR activation promotes Treg function suppressing autoreactive T cells. Vitamin D deficiency → reduced Treg → increased autoreactive T cell activity → higher Hashimoto's risk. Ref: NUT_VITD_001"
      }
    },
    "T3_target_tissue_effects": {
      "hair_matrix": "T3-TR-alpha1 in matrix keratinocytes → regulates ~500 target genes including those for anagen duration and keratin production rate. Ref: BIO_MATRIX_001",
      "skin": "T3 regulates epidermal renewal rate — hypothyroidism slows turnover → accumulation → dry, rough skin",
      "mitochondria": "T3 increases mitochondrial biogenesis → more ATP production capacity → higher BMR",
      "gut": "T3 regulates intestinal motility — hypothyroidism → constipation (slowed gut transit)"
    },
    "cross_system_connections": {
      "to_hair_system": "Critical regulator of BIO_MATRIX_001 mitotic rate and BIO_FOLLICLE_001 anagen duration",
      "to_energy_system": "T3 drives BIO_MITOCHONDRIA_001 biogenesis and BIO_ETC_001 complex expression",
      "to_metabolic_system": "Low T3 → reduced BMR → weight gain despite unchanged diet",
      "to_immune_system": "Hashimoto's is an autoimmune condition connecting thyroid to immune dysregulation"
    },
    "nutritional_dependencies": ["NUT_IODINE_001", "NUT_SELENIUM_001", "NUT_IRON_001", "NUT_VITD_001", "NUT_ZINC_001"],
    "hormones_produced": "HOR_THYROID_001",
    "damage_pathways": {
      "autoimmune": "MED_HASHIMOTOS_001",
      "nutritional": ["NUT_IODINE_001", "NUT_SELENIUM_001", "NUT_IRON_001"],
      "inflammatory": ["INF_CHRONIC_001"],
      "stress_cortisol": "HOR_CORTISOL_001",
      "medications": ["MEDS_PPIS_001"]
    },
    "lab_markers": ["LAB_TSH_001", "LAB_FT3_001", "LAB_FT4_001", "LAB_ANTI_TPO_001"],
    "tags": ["thyroid gland", "T3", "T4", "TSH", "TPO", "deiodinase", "selenium", "iodine", "iron-haem", "Hashimoto's", "reverse T3", "NIS", "thyroglobulin", "autoimmune", "Vitamin D"]
