  "ABS_PROTEIN_001": {
    "id": "ABS_PROTEIN_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_PROTEIN_001",
    "primary_site": "Jejunum and Ileum",
    "mechanism": {
      "transporters": "PEPT1 (di/tripeptides), specific amino acid transporters (Na+-dependent)",
      "process": "Gastric HCl denatures protein. Pepsin cleaves into large polypeptides. Pancreatic proteases (trypsin, chymotrypsin) cleave into oligopeptides. Brush border peptidases cleave into amino acids and di/tripeptides. PEPT1 absorbs di/tripeptides efficiently."
    },
    "enhancers": [
      { "factor": "Gastric Acid", "mechanism": "Essential for initial denaturation and pepsinogen activation" }
    ],
    "inhibitors": [
      { "factor": "MEDS_PPIS_001", "mechanism": "Raises gastric pH → impairs initial protein denaturation" },
      { "factor": "Trypsin inhibitors", "mechanism": "Found in raw legumes/soy; blocks pancreatic proteases" }
    ],
    "gut_health_dependencies": ["BIO_GUTLINING_001"]
  },
  "ABS_CARBS_001": {
    "id": "ABS_CARBS_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_CARBS_001",
    "primary_site": "Duodenum and Jejunum",
    "mechanism": {
      "transporters": "SGLT1 (Glucose/Galactose), GLUT5 (Fructose), GLUT2 (basolateral exit)",
      "process": "Salivary/pancreatic amylase breaks down starch to maltose/dextrins. Brush border disaccharidases (sucrase, lactase, maltase) produce monosaccharides. SGLT1 active transport (requires Na+ gradient)."
    },
    "enhancers": [],
    "inhibitors": [
      { "factor": "Soluble Fibre", "mechanism": "Forms viscous gel, slows gastric emptying and enzyme access" },
      { "factor": "Alpha-glucosidase inhibitors", "mechanism": "Medications that block brush border enzymes" }
    ],
    "gut_health_dependencies": ["BIO_GUTLINING_001"]
  },
  "ABS_FATS_001": {
    "id": "ABS_FATS_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_FATS_001",
    "primary_site": "Jejunum",
    "mechanism": {
      "transporters": "CD36, FATP4, passive diffusion",
      "process": "Bile salts emulsify large fat droplets. Pancreatic lipase hydrolyses triglycerides to monoglycerides and free fatty acids. Micelles form and deliver lipids to brush border. Re-esterified in enterocyte, packaged into chylomicrons, enter lymphatics."
    },
    "enhancers": [
      { "factor": "Bile Production", "mechanism": "Essential for micelle formation" }
    ],
    "inhibitors": [
      { "factor": "Bile acid sequestrants", "mechanism": "Bind bile in gut, preventing micelle formation" },
      { "factor": "Orlistat", "mechanism": "Inhibits pancreatic lipase" }
    ],
    "gut_health_dependencies": ["BIO_LIVER_001", "BIO_GUTLINING_001"]
  },
  "ABS_VITD_001": {
    "id": "ABS_VITD_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_VITD_001",
    "primary_site": "Jejunum and Ileum",
    "mechanism": {
      "transporters": "Cholesterol transporters (NPC1L1, SR-B1), passive diffusion",
      "process": "Fat-soluble. Strictly requires bile salts and micelle formation. Incorporated into chylomicrons for lymphatic transport."
    },
    "enhancers": [
      { "factor": "Dietary Fat", "mechanism": "Co-ingestion with fat triggers bile release and micelle formation" }
    ],
    "inhibitors": [
      { "factor": "Fat Malabsorption", "mechanism": "Conditions like Celiac, Crohn's, or cystic fibrosis" },
      { "factor": "Orlistat", "mechanism": "Blocks fat absorption, taking Vitamin D with it" }
    ],
    "gut_health_dependencies": ["ABS_FATS_001", "BIO_LIVER_001"]
  },
  "ABS_B12_001": {
    "id": "ABS_B12_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_B12_001",
    "primary_site": "Terminal Ileum",
    "mechanism": {
      "transporters": "Cubilin-Amnionless (CUBAM) receptor complex",
      "process": "1. Stomach: HCl/pepsin release B12 from food. 2. Binds R-protein (haptocorrin). 3. Duodenum: Pancreatic enzymes degrade R-protein. 4. B12 binds Intrinsic Factor (secreted by gastric parietal cells). 5. Ileum: IF-B12 complex binds cubilin receptor and is endocytosed."
    },
    "enhancers": [
      { "factor": "Gastric Acid", "mechanism": "Crucial for releasing B12 from dietary protein" },
      { "factor": "Intrinsic Factor", "mechanism": "Absolute requirement for receptor binding" }
    ],
    "inhibitors": [
      { "factor": "MEDS_PPIS_001", "mechanism": "Achlorhydria prevents B12 release from food" },
      { "factor": "MEDS_METFORMIN_001", "mechanism": "Calcium-dependent interference with cubilin receptor" },
      { "factor": "Autoantibodies", "mechanism": "Pernicious anaemia (antibodies against IF or parietal cells)" }
    ],
    "gut_health_dependencies": ["BIO_GUTLINING_001"]
  },
  "ABS_VITC_001": {
    "id": "ABS_VITC_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_VITC_001",
    "primary_site": "Jejunum",
    "mechanism": {
      "transporters": "SVCT1 and SVCT2 (Sodium-dependent Vitamin C Transporters)",
      "process": "Active, saturable transport. Absorption is dose-dependent: ~98% at <100mg, drops to ~50% at 1000mg, and <16% at doses over 3000mg. Unabsorbed ascorbate causes osmotic diarrhoea."
    },
    "enhancers": [],
    "inhibitors": [
      { "factor": "Glucose", "mechanism": "High blood glucose competes with dehydroascorbic acid for GLUT transporters" },
      { "factor": "High Dose", "mechanism": "Downregulates SVCT1 expression to prevent toxicity" }
    ],
    "gut_health_dependencies": ["BIO_GUTLINING_001"]
  },
  "ABS_BIOTIN_001": {
    "id": "ABS_BIOTIN_001",
    "node_type": "absorption",
    "version": "1.0",
    "nutrient_ref": "NUT_BIOTIN_001",
    "primary_site": "Jejunum",
    "mechanism": {
