      { "factor": "Anti-seizure meds", "mechanism": "Carbamazepine/Phenytoin compete for absorption" }
    ],
    "gut_health_dependencies": ["BIO_GUTLINING_001"]
  },
  "ABS_FOLATE_001": {
    "id": "ABS_FOLATE_001",
