  "BIO_PITUITARY_001": {
    "id": "BIO_PITUITARY_001",
    "node_type": "biology",
    "version": "2.0",
    "structure": "Pituitary Gland",
    "parent_system": "SYS_HORMONAL_001",
    "definition": "A bilobed neuroendocrine gland weighing approximately 0.5 to 0.6 grams, housed in the sella turcica of the sphenoid bone, connected to the hypothalamus via the pituitary stalk (infundibulum). The most functionally diverse endocrine gland \u2014 its tropic hormones regulate thyroid, adrenal, gonads, growth, and lactation, making it the master orchestrator of the endocrine system.",
    "function": "Anterior pituitary (adenohypophysis \u2014 glandular tissue): produces TSH (thyroid), ACTH (adrenal), LH and FSH (gonads), GH (growth and metabolism), and prolactin (lactation and reproductive function). Posterior pituitary (neurohypophysis \u2014 neural tissue): stores and releases ADH (water balance) and oxytocin (social bonding, labour, lactation) \u2014 these are actually produced in the hypothalamus and transported down.",
    "cellular_populations_anterior": {
      "thyrotrophs": {
        "hormone": "TSH (thyroid-stimulating hormone)",
        "stimulated_by": "Hypothalamic TRH",
        "inhibited_by": "T3 (via D2 conversion of T4 in pituitary itself) \u2014 D2-generated intracellular T3 is the primary suppressor",
        "hair_relevance": "TSH controls thyroid T4 output \u2192 T3 generated by deiodinases \u2192 T3 at BIO_MATRIX_001 and BIO_FOLLICLE_001"
      },
      "corticotrophs": {
        "hormone": "ACTH (adrenocorticotropic hormone)",
        "stimulated_by": "Hypothalamic CRH and vasopressin (synergistic)",
        "inhibited_by": "Cortisol (glucocorticoid receptor in corticotrophs \u2014 negative feedback)",
        "hair_relevance": "ACTH \u2192 BIO_ADRENAL_001 cortisol \u2192 telogen effluvium pathway"
      },
      "gonadotrophs": {
        "hormone": "LH and FSH",
        "stimulated_by": "Hypothalamic GnRH \u2014 PULSATILE secretion is required. Continuous GnRH paradoxically suppresses LH/FSH (basis of GnRH agonist therapy).",
        "LH_FSH_ratio": "Normal LH:FSH ratio 1:1. In PCOS \u2014 elevated LH pulse frequency \u2192 elevated LH:FSH ratio (often greater than 2:1) \u2192 excessive ovarian androgen secretion",
        "hair_relevance": "LH:FSH ratio diagnostic for PCOS \u2014 ref LAB_LH_FSH_RATIO_001. Ovarian androgen \u2192 DHT \u2192 hair loss. Ref: MED_PCOS_001"
      },
      "somatotrophs": {
        "hormone": "GH (growth hormone)",
        "secretion_pattern": "Pulsatile \u2014 largest pulse within 1 hour of N3 deep sleep onset. 70-80 percent of daily GH secreted during sleep.",
        "stimulated_by": "Hypothalamic GHRH, ghrelin (hunger hormone from stomach)",
        "inhibited_by": "Somatostatin, IGF-1 (negative feedback), obesity, hyperglycaemia",
        "GH_IGF1_axis": "GH \u2192 binds GHR in liver \u2192 JAK2/STAT5b signalling \u2192 IGF-1 gene transcription \u2192 IGF-1 secretion \u2192 paracrine and endocrine growth effects. IGF-1 acts on BIO_DERMALPAPILLA_001 and BIO_MATRIX_001 to promote hair growth.",
        "sleep_connection": "Sleep deprivation eliminates the nocturnal GH pulse \u2192 reduced IGF-1 \u2192 impaired hair growth signalling. Ref: SLP_DEEPSLEEP_001"
      },
      "lactotrophs": {
        "hormone": "Prolactin",
        "uniquely_inhibited_by": "Dopamine from hypothalamus (the only anterior pituitary hormone tonically inhibited \u2014 all others are tonically stimulated). Dopamine acts as prolactin-inhibiting factor (PIF).",
        "stimulated_by": "TRH (explains why hypothyroidism causes hyperprolactinaemia), suckling, stress, antidopaminergic drugs",
        "hair_relevance": "Hyperprolactinaemia (elevated prolactin) \u2192 inhibits GnRH pulsatility \u2192 reduced LH and FSH \u2192 hypogonadism \u2192 reduced estrogen in women \u2192 androgen dominance \u2192 hair loss. Elevated prolactin also directly inhibits 5-alpha reductase in some tissues (inconsistent evidence). Hyperprolactinaemia can cause hair loss in women independently of other hormones.",
        "causes_of_elevation": "Pregnancy/breastfeeding (physiological). Hypothyroidism (TRH cross-stimulation). Antipsychotics/antidepressants (dopamine antagonists). Pituitary adenoma (prolactinoma)."
      }
    },
    "molecular_mechanism": {
      "hypothalamic_portal_system": "Hypothalamic releasing hormones secreted into the hypothalamo-hypophyseal portal vessels \u2014 a short portal blood system directly connecting hypothalamus to anterior pituitary. Concentrations in portal blood 1000-fold higher than systemic \u2014 allows hypothalamus to precisely control each pituitary cell type.",
      "GH_pulse_sleep_link": {
        "physiology": "N3 slow-wave sleep \u2192 GHRH secretion from hypothalamus \u2192 GH pulse from somatotrophs. Delta wave EEG activity correlates with GHRH neuron firing. Sleep architecture determines GH secretory pattern.",
        "IGF1_production": "GH binds GHR in hepatocytes \u2192 dimerisation \u2192 JAK2 trans-phosphorylation \u2192 STAT5b phosphorylation \u2192 nuclear transcription \u2192 IGF-1 mRNA \u2192 IGF-1 protein. IGF-1 is the primary growth mediator in peripheral tissues including hair follicle.",
        "sleep_deprivation_effect": "Even one night of significant sleep deprivation suppresses GH secretion by 20 to 30 percent. Chronic sleep deprivation \u2192 chronically reduced GH and IGF-1 \u2192 impaired anagen maintenance. Ref: SLP_DEEPSLEEP_001"
      },
      "TSH_D2_feedback_circuit": {
        "intrapituitary_conversion": "D2 in pituitary thyrotrophs converts circulating T4 \u2192 T3 locally. This locally generated T3 \u2014 not plasma T3 \u2014 provides the primary negative feedback on TSH secretion.",
        "clinical_implication": "A patient can have low FT3 (peripheral tissues T3 deficient) with normal or even low-normal TSH if T4 is normal \u2014 because pituitary D2 is saturated generating adequate local T3. This is why FT3 must be checked independently of TSH when diagnosing tissue hypothyroidism."
      }
    },
    "cross_system_connections": {
      "to_hair_system": "GH/IGF-1 axis supports anagen via BIO_DERMALPAPILLA_001. Prolactin excess impairs GnRH \u2192 androgen effects. TSH controls thyroid which controls BIO_MATRIX_001.",
